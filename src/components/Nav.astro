<header class="sticky top-0 z-50 bg-white border-b border-slate-200">
  <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" style="font-family: 'DM Sans', sans-serif; font-weight: 800; font-size: 1.25rem; color: #0EA5E9; text-decoration: none;">
      SmileCare
    </a>
    <nav class="hidden md:flex items-center gap-6">
      <a href="/" class="text-sm text-slate-600 hover:text-sky-500 transition">Home</a>
      <a href="/contact" class="text-sm text-slate-600 hover:text-sky-500 transition">Contact</a>
      <a href="/login" class="text-sm text-slate-600 hover:text-sky-500 transition">Sign in</a>
      <a href="/signup" class="text-sm font-medium text-white px-5 py-2 rounded-lg transition" style="background: #0EA5E9;">
        Book Now
      </a>
    </nav>
    <button id="menu-btn" aria-label="Open navigation menu" class="md:hidden text-slate-600 focus:outline-none">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100 bg-white px-4 py-4 flex flex-col gap-3">
    <a href="/" class="text-sm text-slate-600">Home</a>
    <a href="/contact" class="text-sm text-slate-600">Contact</a>
    <a href="/login" class="text-sm text-slate-600">Sign in</a>
    <a href="/signup" class="text-sm font-medium text-white px-5 py-2 rounded-lg text-center" style="background: #0EA5E9;">Book Now</a>
  </div>
</header>
<script>
  document.getElementById('menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
