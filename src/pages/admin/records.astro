---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Records" activePage="records">

  <div class="mb-8">
    <h1 style="font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 1.5rem; color: #0F172A;">Dental Records</h1>
    <p class="text-sm text-slate-500 mt-1">Add and view patient records</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    <!-- Add Record Form -->
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
      <h2 style="font-family: 'DM Sans', sans-serif; font-weight: 600; color: #0F172A; margin-bottom: 1.25rem;">Add New Record</h2>
      <div class="mb-4">
        <label class="block text-sm font-medium text-slate-700 mb-1">Patient</label>
        <select id="record-patient" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2">
          <option value="">Select patient</option>
        </select>
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-slate-700 mb-1">Diagnosis</label>
        <textarea id="record-diagnosis" rows="3" placeholder="e.g. Mild cavity on lower left molar"
          class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 resize-none"></textarea>
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-slate-700 mb-1">Treatment done</label>
        <textarea id="record-treatment" rows="3" placeholder="e.g. Composite filling applied"
          class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 resize-none"></textarea>
      </div>
      <div class="mb-6">
        <label class="block text-sm font-medium text-slate-700 mb-1">Next visit date</label>
        <input id="record-next-visit" type="date"
          class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2" />
      </div>
      <p id="record-error" class="text-red-500 text-sm mb-3 hidden"></p>
      <p id="record-success" class="text-emerald-600 text-sm mb-3 hidden">✅ Record saved successfully.</p>
      <button id="save-record-btn"
        class="w-full py-3 rounded-lg text-white font-medium transition"
        style="background: #6366F1;">
        Save Record
      </button>
    </div>

    <!-- Records List -->
    <div>
      <h2 style="font-family: 'DM Sans', sans-serif; font-weight: 600; color: #0F172A; margin-bottom: 1.25rem;">Recent Records</h2>
      <div id="records-list">
        <p class="text-slate-400 text-sm">Loading...</p>
      </div>
    </div>

  </div>

</AdminLayout>

<script>
  import { supabase } from '../../lib/supabase';

  const ADMIN_EMAIL = 'admin@dentalclinic.com';
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) { window.location.href = '/login'; }
  if (session!.user.email !== ADMIN_EMAIL) { window.location.href = '/dashboard'; }

  // Load patients into dropdown
  const { data: patients } = await supabase.from('patients').select('id, full_name').order('full_name');
  const select = document.getElementById('record-patient') as HTMLSelectElement;
  if (patients) {
    patients.forEach(p => {
      const opt = document.createElement('option');
      opt.value = p.id;
      opt.textContent = p.full_name;
      select.appendChild(opt);
    });
  }

  // Load records
  async function loadRecords() {
    const { data, error } = await supabase
      .from('records')
      .select('*, patients(full_name)')
      .order('created_at', { ascending: false })
      .limit(20);

    const el = document.getElementById('records-list')!;
    if (error || !data || data.length === 0) {
      el.innerHTML = '<p class="text-slate-400 text-sm">No records yet.</p>';
      return;
    }
    el.innerHTML = data.map(r => `
      <div class="bg-white border border-slate-200 rounded-xl p-4 mb-3 shadow-sm">
        <div class="flex justify-between items-start mb-2">
          <p class="font-medium text-slate-900" style="font-family: 'DM Sans', sans-serif;">${(r.patients as any)?.full_name || 'Unknown'}</p>
          <p class="text-xs text-slate-400" style="font-family: 'JetBrains Mono', monospace;">${r.created_at?.split('T')[0]}</p>
        </div>
        <p class="text-sm text-slate-600 mb-1"><span class="font-medium">Diagnosis:</span> ${r.diagnosis || '—'}</p>
        <p class="text-sm text-slate-600 mb-1"><span class="font-medium">Treatment:</span> ${r.treatment_done || '—'}</p>
        ${r.next_visit ? `<p class="text-sm text-slate-500 mt-1">Next visit: <span style="font-family: 'JetBrains Mono', monospace;">${r.next_visit}</span></p>` : ''}
      </div>
    `).join('');
  }

  loadRecords();

  // Save record
  document.getElementById('save-record-btn')?.addEventListener('click', async () => {
    const patientId = (document.getElementById('record-patient') as HTMLSelectElement).value;
    const diagnosis = (document.getElementById('record-diagnosis') as HTMLTextAreaElement).value;
    const treatment = (document.getElementById('record-treatment') as HTMLTextAreaElement).value;
    const nextVisit = (document.getElementById('record-next-visit') as HTMLInputElement).value;
    const errorEl = document.getElementById('record-error')!;
    const successEl = document.getElementById('record-success')!;
    const btn = document.getElementById('save-record-btn') as HTMLButtonElement;

    errorEl.classList.add('hidden');
    successEl.classList.add('hidden');

    if (!patientId || !diagnosis) {
      errorEl.textContent = 'Please select a patient and enter a diagnosis.';
      errorEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Saving...';

    const { error } = await supabase.from('records').insert({
      patient_id: patientId,
      diagnosis,
      treatment_done: treatment || null,
      next_visit: nextVisit || null,
      created_by: 'admin',
    });

    if (error) {
      errorEl.textContent = 'Failed to save record. Please try again.';
      errorEl.classList.remove('hidden');
    } else {
      successEl.classList.remove('hidden');
      (document.getElementById('record-patient') as HTMLSelectElement).value = '';
      (document.getElementById('record-diagnosis') as HTMLTextAreaElement).value = '';
      (document.getElementById('record-treatment') as HTMLTextAreaElement).value = '';
      (document.getElementById('record-next-visit') as HTMLInputElement).value = '';
      loadRecords();
    }

    btn.disabled = false;
    btn.textContent = 'Save Record';
  });
</script>
