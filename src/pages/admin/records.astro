---
import AdminLayout from '../../layouts/AdminLayout.astro';

// -- Run in Supabase SQL Editor:
// -- CREATE POLICY "Admin can delete records"
// -- ON records FOR DELETE
// -- USING (auth.email() = 'admin@dental.com');
// -- GRANT DELETE ON public.records TO authenticated;
---
<AdminLayout title="Records" activePage="records">

  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="font-['DM_Sans'] font-bold text-[1.375rem] text-slate-900 m-0">Dental Records</h1>
      <p class="text-[0.8125rem] text-slate-400 mt-1">Add and view patient treatment history</p>
    </div>
  </div>

  <!-- Responsive grid: stacked on mobile, side-by-side on lg+ -->
  <div class="grid grid-cols-1 lg:grid-cols-[360px_1fr] gap-6 items-start">

    <!-- Form panel -->
    <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6 lg:sticky lg:top-6">
      <p class="font-['DM_Sans'] font-semibold text-slate-900 text-[0.9375rem] m-0 mb-5">New Record</p>

      <div class="mb-4 relative dropdown-container">
        <label class="block text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wide mb-1.5">Patient</label>
        <input id="record-patient-input" type="text" autocomplete="off" placeholder="Search patient..."
          class="w-full border border-slate-200 rounded-lg px-3 py-2.5 text-[0.8125rem] text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-500 box-border" />
        <input type="hidden" id="record-patient" />
        <div id="patient-combobox-dropdown" class="absolute z-20 w-full bg-white border border-slate-200 rounded-lg shadow-lg hidden max-h-60 overflow-y-auto mt-1"></div>
      </div>

      <div class="mb-4">
        <label class="block text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wide mb-1.5">Diagnosis</label>
        <textarea id="record-diagnosis" rows="3" placeholder="e.g. Mild cavity on lower left molar"
          class="w-full border border-slate-200 rounded-lg px-3 py-2.5 text-[0.8125rem] text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-500 resize-none box-border"></textarea>
      </div>

      <div class="mb-4">
        <label class="block text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wide mb-1.5">Treatment Done</label>
        <textarea id="record-treatment" rows="3" placeholder="e.g. Composite filling applied"
          class="w-full border border-slate-200 rounded-lg px-3 py-2.5 text-[0.8125rem] text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-500 resize-none box-border"></textarea>
      </div>

      <div class="mb-5">
        <label class="block text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wide mb-1.5">Next Visit</label>
        <input id="record-next-visit" type="date"
          class="w-full border border-slate-200 rounded-lg px-3 py-2.5 text-[0.8125rem] text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-500 box-border font-mono" />
      </div>

      <p id="record-error" class="text-red-500 text-xs mb-3 hidden"></p>
      <p id="record-success" class="text-green-500 text-xs mb-3 hidden">Record saved successfully.</p>

      <button id="save-record-btn"
        class="w-full p-[0.6875rem] rounded-lg bg-indigo-500 text-white text-[0.8125rem] font-semibold cursor-pointer transition-colors duration-150 font-['DM_Sans'] hover:bg-indigo-600 border-none">
        Save Record
      </button>
    </div>

    <!-- Records list -->
    <div>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
        <p class="font-['DM_Sans'] font-semibold text-slate-900 text-[0.9375rem]">Recent Records</p>
        <select id="filter-patient" class="border border-slate-200 rounded-lg px-3 py-2 text-[0.8125rem] text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-500 w-full sm:w-auto">
          <option value="">All patients</option>
        </select>
      </div>

      <!-- Inline delete error banner (shown below filter row on failure) -->
      <div id="delete-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-[0.8125rem]"></div>

      <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
        <div id="records-list">
          <div class="p-12 flex justify-center"><div class="w-6 h-6 border-2 border-sky-200 border-t-sky-500 rounded-full animate-spin"></div></div>
        </div>
      </div>
    </div>

  </div>

  <!-- Delete Confirmation Modal -->
  <div id="delete-modal" class="fixed inset-0 z-[200] flex items-center justify-center hidden" role="dialog" aria-modal="true" aria-labelledby="delete-modal-title">
    <!-- Overlay -->
    <div id="delete-modal-overlay" class="absolute inset-0 bg-slate-900/50"></div>
    <!-- Card -->
    <div class="relative bg-white rounded-xl shadow-xl p-6 w-full max-w-sm mx-4 font-['DM_Sans']">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 6v4M10 14h.01M19 10a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke="#EF4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h2 id="delete-modal-title" class="font-bold text-slate-900 text-base">Delete record?</h2>
      </div>
      <p class="text-sm text-slate-500 mb-5 pl-[3.25rem]">This will permanently remove the patient's dental record. This action cannot be undone.</p>
      <div class="flex gap-3">
        <button id="delete-modal-back" class="flex-1 py-2.5 rounded-lg border border-slate-200 text-slate-700 text-sm font-medium hover:bg-slate-50 transition">
          Go back
        </button>
        <button id="delete-modal-confirm" class="flex-1 py-2.5 rounded-lg bg-red-500 text-white text-sm font-medium hover:bg-red-600 transition disabled:opacity-50 disabled:cursor-not-allowed">
          Yes, delete record
        </button>
      </div>
    </div>
  </div>

</AdminLayout>

<script>
  import { supabase } from '../../lib/supabase';
  import { escapeHTML } from '../../lib/utils';

  const { data: patients } = await supabase
    .from('patients')
    .select('id, full_name')
    .order('full_name');

  const patientInput = document.getElementById('record-patient-input') as HTMLInputElement;
  const hiddenPatientId = document.getElementById('record-patient') as HTMLInputElement;
  const patientDropdown = document.getElementById('patient-combobox-dropdown')!;

  const filterSelect = document.getElementById('filter-patient') as HTMLSelectElement;

  function renderCombobox(list: any[]) {
    if (list.length === 0) {
      patientDropdown.innerHTML = '<div class="px-3 py-2 text-[0.8125rem] text-slate-400">No matching patients</div>';
      return;
    }
    patientDropdown.innerHTML = list.map(p => `
      <div class="px-3 py-2 text-[0.8125rem] text-slate-700 hover:bg-slate-50 cursor-pointer combobox-option transition-colors" data-id="${p.id}" data-name="${escapeHTML(p.full_name)}">
        ${escapeHTML(p.full_name)}
      </div>
    `).join('');
  }

  if (patients) {
    patients.forEach((p: any) => {
      const opt = document.createElement('option');
      opt.value = p.id;
      opt.textContent = p.full_name;
      filterSelect.appendChild(opt);
    });

    renderCombobox(patients);

    patientInput.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value.toLowerCase();
      hiddenPatientId.value = ''; // clear on typing
      renderCombobox(patients.filter(p => p.full_name.toLowerCase().includes(val)));
      patientDropdown.classList.remove('hidden');
    });

    patientInput.addEventListener('focus', () => {
      patientDropdown.classList.remove('hidden');
    });

    patientDropdown.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement).closest('.combobox-option');
      if (target) {
        hiddenPatientId.value = target.getAttribute('data-id') || '';
        patientInput.value = target.getAttribute('data-name') || '';
        patientDropdown.classList.add('hidden');
      }
    });

    // Handle keyboard nav
    patientInput.addEventListener('keydown', (e) => {
      const options = Array.from(patientDropdown.querySelectorAll('.combobox-option'));
      const active = document.activeElement;
      
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        patientDropdown.classList.remove('hidden');
        if (options.length > 0) (options[0] as HTMLElement).focus();
      } else if (e.key === 'Escape') {
        patientDropdown.classList.add('hidden');
      }
    });
  }

  // Handle unsaved changes warning
  let hasUnsavedChanges = false;
  const markUnsaved = () => hasUnsavedChanges = true;
  document.getElementById('record-diagnosis')?.addEventListener('input', markUnsaved);
  document.getElementById('record-treatment')?.addEventListener('input', markUnsaved);

  window.addEventListener('beforeunload', (e) => {
    if (hasUnsavedChanges) {
      e.preventDefault();
      e.returnValue = '';
    }
  });

  async function loadRecords(patientFilter = '') {
    let query = supabase
      .from('records')
      .select('*, patients(full_name)')
      .order('created_at', { ascending: false })
      .limit(30);

    if (patientFilter) query = query.eq('patient_id', patientFilter);

    const { data, error } = await query;
    const el = document.getElementById('records-list')!;

    if (error || !data || data.length === 0) {
      el.innerHTML = `
        <div class="p-12 text-center flex flex-col items-center justify-center">
          <svg class="w-12 h-12 text-slate-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          <p class="font-medium text-slate-900 text-[0.9375rem] mb-1">No records yet</p>
          <p class="text-slate-500 text-[0.8125rem]">Select a patient and add their first record.</p>
        </div>`;
      return;
    }

    el.innerHTML = data.map((r: any, i: number) => `
      <div class="py-5 px-4 sm:px-6 transition-colors duration-100 hover:bg-slate-50 ${i < data.length - 1 ? 'border-b border-slate-50' : ''}">
        <div class="flex items-start justify-between mb-3 gap-3">
          <div class="min-w-0">
            <p class="font-['DM_Sans'] font-semibold text-slate-900 text-sm m-0 truncate">${escapeHTML((r.patients as any)?.full_name || 'Unknown')}</p>
            <p class="font-mono text-[0.6875rem] text-slate-400 mt-0.5">${escapeHTML(r.created_at?.split('T')[0])}</p>
          </div>
          <div class="flex flex-col items-end gap-2 shrink-0">
            <button onclick="window.openDeleteModal('${escapeHTML(r.id)}')" class="p-1.5 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-md transition-colors btn-press focus:outline-none focus:ring-2 focus:ring-sky-500" aria-label="Delete Record">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
            ${r.next_visit ? `
              <div class="bg-green-50 border border-green-200 rounded-md px-2.5 py-1 text-right mt-1">
                <p class="text-[0.625rem] text-green-600 font-semibold uppercase tracking-wide">Next visit</p>
                <p class="font-mono text-[0.6875rem] text-green-700">${escapeHTML(r.next_visit)}</p>
              </div>` : ''}
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <p class="text-[0.625rem] font-semibold text-slate-400 uppercase tracking-wide mb-1">Diagnosis</p>
            <p class="text-[0.8125rem] text-slate-700">${escapeHTML(r.diagnosis || '—')}</p>
          </div>
          ${r.treatment_done ? `
          <div>
            <p class="text-[0.625rem] font-semibold text-slate-400 uppercase tracking-wide mb-1">Treatment</p>
            <p class="text-[0.8125rem] text-slate-700">${escapeHTML(r.treatment_done)}</p>
          </div>` : ''}
        </div>
      </div>
    `).join('');
  }

  loadRecords();

  filterSelect?.addEventListener('change', (e) => {
    loadRecords((e.target as HTMLSelectElement).value);
  });

  document.getElementById('save-record-btn')?.addEventListener('click', async () => {
    const patientId = (document.getElementById('record-patient') as HTMLSelectElement).value;
    const diagnosis = (document.getElementById('record-diagnosis') as HTMLTextAreaElement).value;
    const treatment = (document.getElementById('record-treatment') as HTMLTextAreaElement).value;
    const nextVisit = (document.getElementById('record-next-visit') as HTMLInputElement).value;
    const errorEl = document.getElementById('record-error') as HTMLElement;
    const successEl = document.getElementById('record-success') as HTMLElement;
    const btn = document.getElementById('save-record-btn') as HTMLButtonElement;

    errorEl.classList.add('hidden');
    successEl.classList.add('hidden');

    if (!patientId || !diagnosis) {
      errorEl.textContent = 'Please select a patient and enter a diagnosis.';
      errorEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Saving...';

    const { error } = await supabase.from('records').insert({
      patient_id: patientId,
      diagnosis,
      treatment_done: treatment || null,
      next_visit: nextVisit || null,
      created_by: 'admin',
    });

    if (error) {
      console.error('Save record error:', error);
      errorEl.textContent = 'Failed to save. Please try again.';
      errorEl.classList.remove('hidden');
    } else {
      successEl.classList.remove('hidden');
      hasUnsavedChanges = false;
      hiddenPatientId.value = '';
      patientInput.value = '';
      (document.getElementById('record-diagnosis') as HTMLTextAreaElement).value = '';
      (document.getElementById('record-treatment') as HTMLTextAreaElement).value = '';
      (document.getElementById('record-next-visit') as HTMLInputElement).value = '';
      loadRecords();
    }

    btn.disabled = false;
    btn.textContent = 'Save Record';
  });

  // --- Delete Modal Logic ---
  let pendingDeleteId: string | null = null;

  (window as any).openDeleteModal = (id: string) => {
    pendingDeleteId = id;
    const modal = document.getElementById('delete-modal');
    modal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  };

  function closeDeleteModal() {
    const modal = document.getElementById('delete-modal');
    modal?.classList.add('hidden');
    document.body.style.overflow = '';
    pendingDeleteId = null;
  }

  document.getElementById('delete-modal-back')?.addEventListener('click', closeDeleteModal);
  document.getElementById('delete-modal-overlay')?.addEventListener('click', closeDeleteModal);

  document.getElementById('delete-modal-confirm')?.addEventListener('click', async () => {
    if (!pendingDeleteId) return;

    const confirmBtn = document.getElementById('delete-modal-confirm') as HTMLButtonElement;
    confirmBtn.disabled = true;
    confirmBtn.textContent = 'Deleting...';

    const { error } = await supabase.from('records').delete().eq('id', pendingDeleteId);

    if (error) {
      console.error('Delete record error:', error);
      closeDeleteModal();
      const bannerEl = document.getElementById('delete-error');
      if (bannerEl) {
        bannerEl.textContent = 'Failed to delete record. Please try again.';
        bannerEl.classList.remove('hidden');
        setTimeout(() => bannerEl.classList.add('hidden'), 5000);
      }
    } else {
      closeDeleteModal();
      loadRecords((document.getElementById('filter-patient') as HTMLSelectElement).value);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDeleteModal();
  });
</script>
