---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Records" activePage="records">

  <!-- Header -->
  <div class="mb-8">
    <h1 style="font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 1.5rem; color: #0F172A;">Dental Records</h1>
    <p class="text-sm text-slate-500 mt-1">Add and view patient treatment records</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

    <!-- Add Record Form (2 cols) -->
    <div class="lg:col-span-2">
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm sticky top-8">
        <div class="flex items-center gap-3 mb-6">
          <div style="width:36px;height:36px;background:#EDE9FE;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;">📁</div>
          <h2 style="font-family:'DM Sans',sans-serif;font-weight:600;color:#0F172A;font-size:1rem;">New Record</h2>
        </div>

        <div class="mb-4">
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Patient</label>
          <select id="record-patient" class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm bg-white focus:outline-none focus:ring-2 text-slate-900">
            <option value="">Select patient...</option>
          </select>
        </div>

        <div class="mb-4">
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Diagnosis</label>
          <textarea id="record-diagnosis" rows="3" placeholder="e.g. Mild cavity on lower left molar"
            class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 resize-none text-slate-900"></textarea>
        </div>

        <div class="mb-4">
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Treatment Done</label>
          <textarea id="record-treatment" rows="3" placeholder="e.g. Composite filling applied"
            class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 resize-none text-slate-900"></textarea>
        </div>

        <div class="mb-6">
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Next Visit</label>
          <input id="record-next-visit" type="date"
            class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 text-slate-900" />
        </div>

        <p id="record-error" class="text-red-500 text-sm mb-3 hidden"></p>
        <p id="record-success" class="text-emerald-600 text-sm mb-3 hidden">✅ Record saved successfully.</p>

        <button id="save-record-btn"
          class="w-full py-3 rounded-xl text-white font-semibold text-sm transition"
          style="background: linear-gradient(135deg, #6366F1, #4F46E5);">
          Save Record
        </button>
      </div>
    </div>

    <!-- Records List (3 cols) -->
    <div class="lg:col-span-3">
      <div class="flex items-center justify-between mb-4">
        <h2 style="font-family:'DM Sans',sans-serif;font-weight:600;color:#0F172A;font-size:1rem;">Recent Records</h2>
        <select id="filter-patient" class="border border-slate-200 rounded-xl px-3 py-2 text-sm bg-white focus:outline-none text-slate-600">
          <option value="">All patients</option>
        </select>
      </div>
      <div id="records-list" class="space-y-3">
        <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm animate-pulse">
          <div class="h-4 bg-slate-100 rounded mb-3 w-1/2"></div>
          <div class="h-3 bg-slate-100 rounded mb-2 w-3/4"></div>
          <div class="h-3 bg-slate-100 rounded w-2/3"></div>
        </div>
      </div>
    </div>

  </div>

</AdminLayout>

<script>
  import { supabase } from '../../lib/supabase';

  const ADMIN_EMAIL = 'admin@dentalclinic.com';
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) { window.location.href = '/login'; }
  if (session!.user.email !== ADMIN_EMAIL) { window.location.href = '/dashboard'; }

  // Load patients into both dropdowns
  const { data: patients } = await supabase
    .from('patients')
    .select('id, full_name')
    .order('full_name');

  const recordSelect = document.getElementById('record-patient') as HTMLSelectElement;
  const filterSelect = document.getElementById('filter-patient') as HTMLSelectElement;

  if (patients) {
    patients.forEach(p => {
      const opt1 = document.createElement('option');
      opt1.value = p.id;
      opt1.textContent = p.full_name;
      recordSelect.appendChild(opt1);

      const opt2 = document.createElement('option');
      opt2.value = p.id;
      opt2.textContent = p.full_name;
      filterSelect.appendChild(opt2);
    });
  }

  async function loadRecords(patientFilter = '') {
    let query = supabase
      .from('records')
      .select('*, patients(full_name)')
      .order('created_at', { ascending: false })
      .limit(30);

    if (patientFilter) query = query.eq('patient_id', patientFilter);

    const { data, error } = await query;
    const el = document.getElementById('records-list')!;

    if (error || !data || data.length === 0) {
      el.innerHTML = `
        <div class="bg-white border border-slate-200 rounded-2xl p-10 text-center shadow-sm">
          <p class="text-3xl mb-2">📋</p>
          <p class="text-slate-400 text-sm">No records yet.</p>
        </div>`;
      return;
    }

    el.innerHTML = data.map(r => `
      <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-3">
            <div style="width:36px;height:36px;background:#EDE9FE;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:0.9rem;">🦷</div>
            <div>
              <p style="font-family:'DM Sans',sans-serif;font-weight:600;color:#0F172A;font-size:0.9rem;">${(r.patients as any)?.full_name || 'Unknown'}</p>
              <p class="text-xs text-slate-400" style="font-family:'JetBrains Mono',monospace;">${r.created_at?.split('T')[0]}</p>
            </div>
          </div>
          ${r.next_visit ? `
            <div style="background:#F0FDF4;border:1px solid #BBF7D0;border-radius:8px;padding:4px 10px;text-align:center;">
              <p class="text-xs text-emerald-600 font-medium">Next visit</p>
              <p class="text-xs text-emerald-700 font-mono">${r.next_visit}</p>
            </div>` : ''}
        </div>
        <div class="space-y-2 border-t border-slate-100 pt-3">
          <div>
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-0.5">Diagnosis</p>
            <p class="text-sm text-slate-700">${r.diagnosis || '—'}</p>
          </div>
          ${r.treatment_done ? `
          <div>
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-0.5">Treatment</p>
            <p class="text-sm text-slate-700">${r.treatment_done}</p>
          </div>` : ''}
        </div>
      </div>
    `).join('');
  }

  loadRecords();

  filterSelect?.addEventListener('change', (e) => {
    loadRecords((e.target as HTMLSelectElement).value);
  });

  // Save record
  document.getElementById('save-record-btn')?.addEventListener('click', async () => {
    const patientId = (document.getElementById('record-patient') as HTMLSelectElement).value;
    const diagnosis = (document.getElementById('record-diagnosis') as HTMLTextAreaElement).value;
    const treatment = (document.getElementById('record-treatment') as HTMLTextAreaElement).value;
    const nextVisit = (document.getElementById('record-next-visit') as HTMLInputElement).value;
    const errorEl = document.getElementById('record-error')!;
    const successEl = document.getElementById('record-success')!;
    const btn = document.getElementById('save-record-btn') as HTMLButtonElement;

    errorEl.classList.add('hidden');
    successEl.classList.add('hidden');

    if (!patientId || !diagnosis) {
      errorEl.textContent = 'Please select a patient and enter a diagnosis.';
      errorEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Saving...';

    const { error } = await supabase.from('records').insert({
      patient_id: patientId,
      diagnosis,
      treatment_done: treatment || null,
      next_visit: nextVisit || null,
      created_by: 'admin',
    });

    if (error) {
      errorEl.textContent = 'Failed to save. Please try again.';
      errorEl.classList.remove('hidden');
    } else {
      successEl.classList.remove('hidden');
      (document.getElementById('record-patient') as HTMLSelectElement).value = '';
      (document.getElementById('record-diagnosis') as HTMLTextAreaElement).value = '';
      (document.getElementById('record-treatment') as HTMLTextAreaElement).value = '';
      (document.getElementById('record-next-visit') as HTMLInputElement).value = '';
      loadRecords();
    }

    btn.disabled = false;
    btn.textContent = 'Save Record';
  });
</script>
