---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Appointments" activePage="dashboard">

  <div class="mb-8">
    <h1 style="font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 1.5rem; color: #0F172A;">Appointments</h1>
    <p class="text-sm text-slate-500 mt-1">Manage all patient appointments</p>
  </div>

  <!-- Stats row -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    {[
      { id: 'stat-total',     label: 'Total' },
      { id: 'stat-pending',   label: 'Pending' },
      { id: 'stat-confirmed', label: 'Confirmed' },
      { id: 'stat-today',     label: 'Today' },
    ].map(s => (
      <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
        <p id={s.id} style="font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 1.875rem; color: #6366F1;">—</p>
        <p class="text-sm text-slate-500 mt-1">{s.label}</p>
      </div>
    ))}
  </div>

  <!-- Filter -->
  <div class="flex items-center gap-3 mb-4">
    <select id="status-filter" class="border border-slate-200 rounded-lg px-3 py-2 text-sm text-slate-700 bg-white focus:outline-none focus:ring-2">
      <option value="all">All statuses</option>
      <option value="pending">Pending</option>
      <option value="confirmed">Confirmed</option>
      <option value="cancelled">Cancelled</option>
      <option value="completed">Completed</option>
    </select>
  </div>

  <!-- Table -->
  <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead style="background: #F8FAFC; border-bottom: 1px solid #E2E8F0;">
        <tr>
          <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">Patient</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">Date</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">Time</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">Treatment</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">Status</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody id="appointments-tbody">
        <tr><td colspan="6" class="px-4 py-6 text-center text-slate-400 text-sm">Loading...</td></tr>
      </tbody>
    </table>
  </div>

</AdminLayout>

<script>
  import { supabase } from '../../lib/supabase';

  const ADMIN_EMAIL = 'admin@dentalclinic.com';

  // Auth guard
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) { window.location.href = '/login'; }
  if (session!.user.email !== ADMIN_EMAIL) { window.location.href = '/dashboard'; }

  async function loadAppointments(statusFilter = 'all') {
    let query = supabase
      .from('appointments')
      .select('*, patients(full_name, phone)')
      .order('appointment_date', { ascending: true });

    if (statusFilter !== 'all') query = query.eq('status', statusFilter);

    const { data, error } = await query;
    if (error) { console.error(error); return; }

    // Stats
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('stat-total')!.textContent = String(data.length);
    document.getElementById('stat-pending')!.textContent = String(data.filter(a => a.status === 'pending').length);
    document.getElementById('stat-confirmed')!.textContent = String(data.filter(a => a.status === 'confirmed').length);
    document.getElementById('stat-today')!.textContent = String(data.filter(a => a.appointment_date === today).length);

    // Table
    const tbody = document.getElementById('appointments-tbody')!;
    if (data.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="px-4 py-6 text-center text-slate-400 text-sm">No appointments found.</td></tr>';
      return;
    }

    tbody.innerHTML = data.map(a => `
      <tr style="border-bottom: 1px solid #F1F5F9;">
        <td class="px-4 py-3 font-medium text-slate-900">${(a.patients as any)?.full_name || 'Unknown'}</td>
        <td class="px-4 py-3 text-slate-600" style="font-family: 'JetBrains Mono', monospace;">${a.appointment_date}</td>
        <td class="px-4 py-3 text-slate-600" style="font-family: 'JetBrains Mono', monospace;">${a.appointment_time}</td>
        <td class="px-4 py-3 text-slate-700">${a.treatment_type}</td>
        <td class="px-4 py-3"><span class="status-${a.status}">${a.status}</span></td>
        <td class="px-4 py-3">
          <div class="flex gap-2">
            <button onclick="updateStatus('${a.id}', 'confirmed')"
              style="font-size: 0.75rem; border: 1px solid #A7F3D0; color: #065F46; padding: 2px 8px; border-radius: 4px; background: white; cursor: pointer;">
              Confirm
            </button>
            <button onclick="updateStatus('${a.id}', 'cancelled')"
              style="font-size: 0.75rem; border: 1px solid #FECACA; color: #991B1B; padding: 2px 8px; border-radius: 4px; background: white; cursor: pointer;">
              Cancel
            </button>
            <button onclick="updateStatus('${a.id}', 'completed')"
              style="font-size: 0.75rem; border: 1px solid #E2E8F0; color: #475569; padding: 2px 8px; border-radius: 4px; background: white; cursor: pointer;">
              Done
            </button>
          </div>
        </td>
      </tr>
    `).join('');
  }

  (window as any).updateStatus = async (id: string, status: string) => {
    await supabase.from('appointments').update({ status }).eq('id', id);
    loadAppointments((document.getElementById('status-filter') as HTMLSelectElement).value);
  };

  document.getElementById('status-filter')?.addEventListener('change', (e) => {
    loadAppointments((e.target as HTMLSelectElement).value);
  });

  loadAppointments();
</script>
