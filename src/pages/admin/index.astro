---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Appointments" activePage="dashboard">

  <!-- Page header -->
  <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-8 gap-4">
    <div>
      <h1 class="font-['DM_Sans'] font-bold text-[1.375rem] text-slate-900 m-0">Appointments</h1>
      <p class="text-[0.8125rem] text-slate-400 mt-1">Manage and update patient appointment status</p>
    </div>
    <div class="flex gap-3 items-center">
      <select id="status-filter" class="border border-slate-200 rounded-lg py-2 px-3 text-[0.8125rem] text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-500 cursor-pointer">
        <option value="all">All statuses</option>
        <option value="pending">Pending</option>
        <option value="confirmed">Confirmed</option>
        <option value="cancelled">Cancelled</option>
        <option value="completed">Completed</option>
      </select>
    </div>
  </div>

  <!-- Stats row -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white border border-slate-200 border-t-[3px] border-t-indigo-500 rounded-xl p-5 shadow-sm">
      <p id="stat-total" class="font-['DM_Sans'] font-extrabold text-3xl text-slate-900 leading-none m-0">—</p>
      <p class="text-xs text-slate-400 mt-2 uppercase tracking-wider font-medium">Total</p>
    </div>
    <div class="bg-white border border-slate-200 border-t-[3px] border-t-amber-500 rounded-xl p-5 shadow-sm">
      <p id="stat-pending" class="font-['DM_Sans'] font-extrabold text-3xl text-slate-900 leading-none m-0">—</p>
      <p class="text-xs text-slate-400 mt-2 uppercase tracking-wider font-medium">Pending</p>
    </div>
    <div class="bg-white border border-slate-200 border-t-[3px] border-t-emerald-500 rounded-xl p-5 shadow-sm">
      <p id="stat-confirmed" class="font-['DM_Sans'] font-extrabold text-3xl text-slate-900 leading-none m-0">—</p>
      <p class="text-xs text-slate-400 mt-2 uppercase tracking-wider font-medium">Confirmed</p>
    </div>
    <div class="bg-white border border-slate-200 border-t-[3px] border-t-sky-500 rounded-xl p-5 shadow-sm">
      <p id="stat-today" class="font-['DM_Sans'] font-extrabold text-3xl text-slate-900 leading-none m-0">—</p>
      <p class="text-xs text-slate-400 mt-2 uppercase tracking-wider font-medium">Today</p>
    </div>
  </div>

  <!-- Filter Bar -->
  <div class="flex flex-col md:flex-row gap-4 items-stretch md:items-center mb-6">
    <div class="relative flex-1">
      <input type="text" id="search-input" placeholder="Search by patient name..." 
        class="w-full border border-slate-200 rounded-lg py-2 pl-9 pr-3 text-[0.8125rem] text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-500" />
      <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">⌕</span>
    </div>
    
    <div class="flex gap-2 overflow-x-auto pb-1 md:pb-0 hide-scroll">
      <button class="date-filter-btn shrink-0 bg-sky-500 text-white border-sky-500 border rounded-lg py-1.5 px-3 text-xs font-medium transition-colors" data-filter="all">All</button>
      <button class="date-filter-btn shrink-0 bg-white text-slate-500 border-slate-200 border rounded-lg py-1.5 px-3 text-xs font-medium transition-colors hover:bg-slate-50" data-filter="today">Today</button>
      <button class="date-filter-btn shrink-0 bg-white text-slate-500 border-slate-200 border rounded-lg py-1.5 px-3 text-xs font-medium transition-colors hover:bg-slate-50" data-filter="week">This Week</button>
      <button class="date-filter-btn shrink-0 bg-white text-slate-500 border-slate-200 border rounded-lg py-1.5 px-3 text-xs font-medium transition-colors hover:bg-slate-50" data-filter="month">This Month</button>
    </div>
  </div>

  <!-- Delete Error Banner -->
  <div id="delete-error" class="hidden mb-6 p-4 rounded-lg bg-red-50 border border-red-100 text-sm items-start gap-3 transition-opacity">
    <span class="text-red-500 text-lg leading-none mt-0.5">⚠</span>
    <div>
      <p class="font-medium text-red-800">Failed to delete appointment</p>
      <p id="delete-error-msg" class="text-red-600 mt-0.5"></p>
    </div>
  </div>

  <!-- Table -->
  <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
    <div class="py-4 px-6 border-b border-slate-100 flex items-center justify-between">
      <p class="text-[0.8125rem] font-semibold text-slate-900">All Appointments</p>
      <p id="row-count" class="text-xs text-slate-400 font-mono"></p>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-[0.8125rem]">
        <thead>
          <tr class="border-b border-slate-100 bg-slate-50/50">
            <th class="text-left py-3 px-6 text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wider whitespace-nowrap">Patient</th>
            <th class="text-left py-3 px-4 text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wider whitespace-nowrap">Date</th>
            <th class="text-left py-3 px-4 text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wider whitespace-nowrap">Time</th>
            <th class="text-left py-3 px-4 text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wider whitespace-nowrap">Treatment</th>
            <th class="text-left py-3 px-4 text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wider whitespace-nowrap">Status</th>
            <th class="text-left py-3 px-6 text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wider whitespace-nowrap">Actions</th>
          </tr>
        </thead>
        <tbody id="appointments-tbody">
          <tr><td colspan="6" class="p-12 text-center text-slate-400 text-[0.8125rem]">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="delete-modal" class="fixed inset-0 z-50 hidden items-center justify-center">
    <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm" onclick="closeDeleteModal()"></div>
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4 relative z-10 overflow-hidden animate-in fade-in zoom-in-95 duration-200">
      <div class="p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
            <span class="text-red-600 text-xl font-bold">!</span>
          </div>
          <h3 class="font-['DM_Sans'] font-bold text-xl text-slate-900 m-0">Delete appointment?</h3>
        </div>
        <p class="text-[0.9375rem] text-slate-500 leading-relaxed">
          This will permanently delete this appointment. This cannot be undone.
        </p>
      </div>
      <div class="bg-slate-50 px-6 py-4 flex items-center justify-end gap-3 border-t border-slate-100">
        <button onclick="closeDeleteModal()" class="px-4 py-2 text-sm font-medium text-slate-600 bg-transparent hover:bg-slate-200 rounded-lg transition-colors">
          Go back
        </button>
        <button onclick="executeDelete()" class="px-4 py-2 text-sm font-medium text-white bg-red-500 hover:bg-red-600 rounded-lg transition-colors shadow-sm">
          Yes, delete appointment
        </button>
      </div>
    </div>
  </div>

</AdminLayout>

<style>
  .hide-scroll::-webkit-scrollbar {
    display: none;
  }
  .hide-scroll {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  import { supabase } from '../../lib/supabase';
  import { escapeHTML } from '../../lib/utils';

  let allAppointments: any[] = [];
  let currentSearchTerm = '';
  let currentDateFilter = 'all';

  async function loadAppointments(statusFilter = 'all') {
    let query = supabase
      .from('appointments')
      .select('*, patients(full_name, phone)')
      .order('appointment_date', { ascending: true });

    if (statusFilter !== 'all') query = query.eq('status', statusFilter);

    const { data, error } = await query;
    if (error) { 
      console.error(error); 
      const tbody = document.getElementById('appointments-tbody');
      if (tbody) {
        tbody.innerHTML = '<tr><td colspan="6" class="p-12 text-center text-red-500 text-[0.8125rem]">Failed to load appointments. Please refresh.</td></tr>';
      }
      return; 
    }

    allAppointments = data || [];
    renderTable();
  }

  function renderTable() {
    const todayStr = new Date().toISOString().split('T')[0];
    const today = new Date(todayStr);

    const filtered = allAppointments.filter(a => {
      // 1. Search Filter
      const nameMatch = a.patients?.full_name?.toLowerCase().includes(currentSearchTerm.toLowerCase());
      if (currentSearchTerm && !nameMatch) return false;

      // 2. Date Filter
      if (currentDateFilter === 'today') {
        return a.appointment_date === todayStr;
      } else if (currentDateFilter === 'week') {
        const appDate = new Date(a.appointment_date);
        const dayOfWeek = today.getDay(); // 0 is Sunday
        const startOfWeek = new Date(today);
        startOfWeek.setDate(today.getDate() - dayOfWeek);
        const endOfWeek = new Date(today);
        endOfWeek.setDate(today.getDate() + (6 - dayOfWeek));
        return appDate >= startOfWeek && appDate <= endOfWeek;
      } else if (currentDateFilter === 'month') {
        return a.appointment_date.startsWith(todayStr.slice(0, 7)); // e.g. "2023-10"
      }
      return true;
    });

    const totalEl = document.getElementById('stat-total');
    const pendingEl = document.getElementById('stat-pending');
    const confirmedEl = document.getElementById('stat-confirmed');
    const todayEl = document.getElementById('stat-today');
    const countEl = document.getElementById('row-count');

    if (totalEl) totalEl.textContent = String(filtered.length);
    if (pendingEl) pendingEl.textContent = String(filtered.filter((a: any) => a.status === 'pending').length);
    if (confirmedEl) confirmedEl.textContent = String(filtered.filter((a: any) => a.status === 'confirmed').length);
    if (todayEl) todayEl.textContent = String(filtered.filter((a: any) => a.appointment_date === todayStr).length);
    if (countEl) countEl.textContent = `${filtered.length} records`;

    const tbody = document.getElementById('appointments-tbody')!;
    if (filtered.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="p-12 text-center text-slate-400 text-[0.8125rem]">No appointments found.</td></tr>';
      return;
    }

    const statusStyles: Record<string, string> = {
      pending:   'bg-amber-100 text-amber-800',
      confirmed: 'bg-emerald-100 text-emerald-800',
      cancelled: 'bg-red-100 text-red-800',
      completed: 'bg-slate-100 text-slate-600',
    };

    const rowColors: Record<string, string> = {
      pending:   'bg-amber-50/30 hover:bg-amber-50',
      confirmed: 'bg-emerald-50/30 hover:bg-emerald-50',
      cancelled: 'bg-red-50/30 hover:bg-red-50',
      completed: 'bg-slate-50/50 hover:bg-slate-100/50',
    };

    tbody.innerHTML = filtered.map((a: any) => {
      const bg = rowColors[a.status] || 'bg-white hover:bg-slate-50';
      
      let actionsHtml = '';
      if (a.status === 'pending') {
        actionsHtml = `
          <button onclick="updateStatus('${escapeHTML(a.id)}','confirmed')" class="text-[0.6875rem] border border-emerald-200 text-emerald-700 py-1 px-2.5 rounded-md bg-white hover:bg-emerald-50 font-medium transition-colors">Confirm</button>
          <button onclick="updateStatus('${escapeHTML(a.id)}','cancelled')" class="text-[0.6875rem] border border-red-200 text-red-700 py-1 px-2.5 rounded-md bg-white hover:bg-red-50 font-medium transition-colors">Cancel</button>
        `;
      } else if (a.status === 'confirmed') {
        actionsHtml = `
          <button onclick="updateStatus('${escapeHTML(a.id)}','completed')" class="text-[0.6875rem] border border-slate-200 text-slate-600 py-1 px-2.5 rounded-md bg-white hover:bg-slate-50 font-medium transition-colors">Done</button>
          <button onclick="updateStatus('${escapeHTML(a.id)}','cancelled')" class="text-[0.6875rem] border border-red-200 text-red-700 py-1 px-2.5 rounded-md bg-white hover:bg-red-50 font-medium transition-colors">Cancel</button>
        `;
      } else if (a.status === 'cancelled') {
        actionsHtml = `<span class="text-[0.6875rem] text-slate-400 font-medium">Cancelled</span>`;
      } else if (a.status === 'completed') {
        actionsHtml = `<span class="text-[0.6875rem] text-slate-400 font-medium">Completed</span>`;
      }

      actionsHtml += `
        <button onclick="confirmDeleteAppointment('${escapeHTML(a.id)}')" class="text-[0.6875rem] border border-red-200 text-red-600 py-1 px-2.5 rounded-md bg-white hover:bg-red-50 font-medium transition-colors ml-2">Delete</button>
      `;

      return `
      <tr class="border-b border-slate-50 ${bg} transition-colors">
        <td class="py-3 px-6">
          <p class="font-medium text-slate-900 text-[0.8125rem] whitespace-nowrap">${escapeHTML(a.patients?.full_name || '—')}</p>
          <p class="text-[0.6875rem] text-slate-400 mt-0.5 whitespace-nowrap">${escapeHTML(a.patients?.phone || '')}</p>
        </td>
        <td class="py-3 px-4 font-mono text-slate-600 text-xs whitespace-nowrap">${escapeHTML(a.appointment_date)}</td>
        <td class="py-3 px-4 font-mono text-slate-600 text-xs whitespace-nowrap">${escapeHTML(a.appointment_time?.slice(0,5))}</td>
        <td class="py-3 px-4 text-slate-700 text-[0.8125rem] whitespace-nowrap">${escapeHTML(a.treatment_type)}</td>
        <td class="py-3 px-4 whitespace-nowrap">
          <span class="${escapeHTML(statusStyles[a.status] || '')} rounded-md py-1 px-2.5 text-[0.6875rem] font-semibold capitalize inline-block">${escapeHTML(a.status)}</span>
        </td>
        <td class="py-3 px-6 whitespace-nowrap">
          <div class="flex gap-2 items-center">
            ${actionsHtml}
          </div>
        </td>
      </tr>
      `;
    }).join('');
  }

  (window as any).updateStatus = async (id: string, status: string) => {
    await supabase.from('appointments').update({ status }).eq('id', id);
    loadAppointments((document.getElementById('status-filter') as HTMLSelectElement).value);
  };

  document.getElementById('status-filter')?.addEventListener('change', (e) => {
    loadAppointments((e.target as HTMLSelectElement).value);
  });

  document.getElementById('search-input')?.addEventListener('input', (e) => {
    currentSearchTerm = (e.target as HTMLInputElement).value;
    renderTable();
  });

  document.querySelectorAll('.date-filter-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.target as HTMLButtonElement;
      currentDateFilter = target.dataset.filter || 'all';
      
      document.querySelectorAll('.date-filter-btn').forEach(b => {
        b.className = 'date-filter-btn shrink-0 bg-white text-slate-500 border-slate-200 border rounded-lg py-1.5 px-3 text-xs font-medium transition-colors hover:bg-slate-50';
      });
      target.className = 'date-filter-btn shrink-0 bg-sky-500 text-white border-sky-500 border rounded-lg py-1.5 px-3 text-xs font-medium transition-colors';

      renderTable();
    });
  });

  let appointmentToDelete: string | null = null;

  (window as any).confirmDeleteAppointment = (id: string) => {
    appointmentToDelete = id;
    const modal = document.getElementById('delete-modal');
    if (modal) modal.classList.replace('hidden', 'flex');
  };

  (window as any).closeDeleteModal = () => {
    appointmentToDelete = null;
    const modal = document.getElementById('delete-modal');
    if (modal) modal.classList.replace('flex', 'hidden');
  };

  (window as any).executeDelete = async () => {
    if (!appointmentToDelete) return;
    const id = appointmentToDelete;
    (window as any).closeDeleteModal();
    
    const { error } = await supabase.from('appointments').delete().eq('id', id);
    
    if (error) {
      console.error('Delete error:', error);
      const errBanner = document.getElementById('delete-error');
      const errMsg = document.getElementById('delete-error-msg');
      if (errBanner && errMsg) {
        errMsg.textContent = error.message || 'Unknown error occurred.';
        errBanner.classList.replace('hidden', 'flex');
        setTimeout(() => errBanner.classList.replace('flex', 'hidden'), 5000);
      }
    } else {
      allAppointments = allAppointments.filter((a: any) => a.id !== id);
      renderTable();
    }
  };

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      (window as any).closeDeleteModal();
    }
  });

  loadAppointments();
</script>
