---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Patients" activePage="patients">

  <div class="mb-8">
    <h1 style="font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 1.5rem; color: #0F172A;">Patients</h1>
    <p class="text-sm text-slate-500 mt-1">All registered patients</p>
  </div>

  <!-- Search -->
  <div class="mb-4">
    <input id="search" type="text" placeholder="Search by name..."
      class="border border-slate-200 rounded-lg px-4 py-2 text-sm text-slate-700 bg-white focus:outline-none focus:ring-2 w-full max-w-sm" />
  </div>

  <!-- Table -->
  <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead style="background: #F8FAFC; border-bottom: 1px solid #E2E8F0;">
        <tr>
          <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">Name</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">Phone</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">Date of Birth</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">Joined</th>
        </tr>
      </thead>
      <tbody id="patients-tbody">
        <tr><td colspan="4" class="px-4 py-6 text-center text-slate-400 text-sm">Loading...</td></tr>
      </tbody>
    </table>
  </div>

</AdminLayout>

<script>
  import { supabase } from '../../lib/supabase';

  const ADMIN_EMAIL = 'admin@dentalclinic.com';
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) { window.location.href = '/login'; }
  if (session!.user.email !== ADMIN_EMAIL) { window.location.href = '/dashboard'; }

  let allPatients: any[] = [];

  const { data, error } = await supabase
    .from('patients')
    .select('*')
    .order('created_at', { ascending: false });

  if (!error) {
    allPatients = data;
    renderPatients(data);
  }

  function renderPatients(patients: any[]) {
    const tbody = document.getElementById('patients-tbody')!;
    if (patients.length === 0) {
      tbody.innerHTML = '<tr><td colspan="4" class="px-4 py-6 text-center text-slate-400 text-sm">No patients found.</td></tr>';
      return;
    }
    tbody.innerHTML = patients.map(p => `
      <tr style="border-bottom: 1px solid #F1F5F9;">
        <td class="px-4 py-3 font-medium text-slate-900">${p.full_name}</td>
        <td class="px-4 py-3 text-slate-600">${p.phone || '—'}</td>
        <td class="px-4 py-3 text-slate-600" style="font-family: 'JetBrains Mono', monospace;">${p.date_of_birth || '—'}</td>
        <td class="px-4 py-3 text-slate-500" style="font-family: 'JetBrains Mono', monospace;">${p.created_at?.split('T')[0] || '—'}</td>
      </tr>
    `).join('');
  }

  document.getElementById('search')?.addEventListener('input', (e) => {
    const q = (e.target as HTMLInputElement).value.toLowerCase();
    renderPatients(allPatients.filter(p => p.full_name.toLowerCase().includes(q)));
  });
</script>
