---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Patients" activePage="patients">

  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h1 class="font-['DM_Sans'] font-bold text-[1.375rem] text-slate-900 m-0">Patients</h1>
      <p class="text-[0.8125rem] text-slate-400 mt-1">All registered patient accounts</p>
    </div>
    <div class="flex items-center gap-3 flex-wrap">
      <p id="total-count" class="text-[0.8125rem] text-slate-400 font-mono"></p>
      <div class="relative">
        <input id="search" type="text" placeholder="Search patients..."
          class="border border-slate-200 rounded-lg py-2 pr-3 pl-9 text-[0.8125rem] text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-500 w-full sm:w-56" />
        <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-slate-400 text-sm">⌕</span>
      </div>
    </div>
  </div>

  <!-- Delete Error Banner -->
  <div id="delete-error" class="hidden mb-6 p-4 rounded-lg bg-red-50 border border-red-100 text-sm items-start gap-3 transition-opacity">
    <span class="text-red-500 text-lg leading-none mt-0.5">⚠</span>
    <div>
      <p class="font-medium text-red-800">Failed to delete patient</p>
      <p id="delete-error-msg" class="text-red-600 mt-0.5"></p>
    </div>
  </div>

  <!-- Table -->
  <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden overflow-x-auto">
    <table class="w-full border-collapse text-[0.8125rem]">
      <thead>
        <tr class="border-b border-slate-100">
          <th class="text-left py-3 px-6 text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wider">Patient</th>
          <th class="text-left py-3 px-4 text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wider">Phone</th>
          <th class="text-left py-3 px-4 text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wider">Date of Birth</th>
          <th class="text-left py-3 px-6 text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wider">Joined</th>
          <th class="text-left py-3 px-6 text-[0.6875rem] font-semibold text-slate-400 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody id="patients-tbody">
        <tr><td colspan="4" class="p-12 text-center text-slate-400 text-[0.8125rem]">Loading...</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="delete-modal" class="fixed inset-0 z-50 hidden items-center justify-center">
    <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm" onclick="closeDeleteModal()"></div>
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4 relative z-10 overflow-hidden animate-in fade-in zoom-in-95 duration-200">
      <div class="p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
            <span class="text-red-600 text-xl font-bold">!</span>
          </div>
          <h3 class="font-['DM_Sans'] font-bold text-xl text-slate-900 m-0">Delete patient?</h3>
        </div>
        <p class="text-[0.9375rem] text-slate-500 leading-relaxed">
          This will permanently delete this patient and ALL their appointments and records. This cannot be undone.
        </p>
      </div>
      <div class="bg-slate-50 px-6 py-4 flex items-center justify-end gap-3 border-t border-slate-100">
        <button onclick="closeDeleteModal()" class="px-4 py-2 text-sm font-medium text-slate-600 bg-transparent hover:bg-slate-200 rounded-lg transition-colors">
          Go back
        </button>
        <button onclick="executeDelete()" class="px-4 py-2 text-sm font-medium text-white bg-red-500 hover:bg-red-600 rounded-lg transition-colors shadow-sm">
          Yes, delete patient
        </button>
      </div>
    </div>
  </div>

</AdminLayout>

<script>
  import { supabase } from '../../lib/supabase';
  import { escapeHTML } from '../../lib/utils';

  let allPatients: any[] = [];

  function getInitials(name: string) {
    return name.split(' ').map((n: string) => n[0]).join('').toUpperCase().slice(0, 2);
  }

  const avatarColors = [
    { bg: 'bg-violet-100', text: 'text-violet-700' },
    { bg: 'bg-blue-100', text: 'text-blue-700' },
    { bg: 'bg-emerald-100', text: 'text-emerald-700' },
    { bg: 'bg-amber-100', text: 'text-amber-700' },
    { bg: 'bg-pink-100', text: 'text-pink-700' },
    { bg: 'bg-sky-100', text: 'text-sky-700' },
  ];

  const { data, error } = await supabase
    .from('patients')
    .select('*')
    .order('created_at', { ascending: false });

  if (error) {
    console.error('Supabase fetch error:', error);
    const tbody = document.getElementById('patients-tbody');
    if (tbody) {
      tbody.innerHTML = `<tr><td colspan="4" class="p-12 text-center text-red-500 text-[0.8125rem]">Failed to load patients: ${escapeHTML(error.message) || 'Unknown error'}</td></tr>`;
    }
  } else if (data) {
    allPatients = data;
    const countEl = document.getElementById('total-count');
    if (countEl) countEl.textContent = `${data.length} patients`;
    renderPatients(data);
  }

  function renderPatients(patients: any[]) {
    const tbody = document.getElementById('patients-tbody')!;
    if (patients.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" class="p-12 text-center text-slate-400 text-[0.8125rem]">No patients found.</td></tr>';
      return;
    }
    tbody.innerHTML = patients.map((p: any) => {
      const color = avatarColors[p.full_name.charCodeAt(0) % avatarColors.length];
      const initials = getInitials(p.full_name);
      return `
        <tr class="border-b border-slate-50 transition-colors duration-100 hover:bg-slate-50">
          <td class="py-3.5 px-6">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg ${color.bg} ${color.text} flex items-center justify-center font-['DM_Sans'] font-bold text-[0.6875rem] shrink-0">${escapeHTML(initials)}</div>
              <span class="font-medium text-slate-900 text-[0.8125rem]">${escapeHTML(p.full_name)}</span>
            </div>
          </td>
          <td class="py-3.5 px-4 text-slate-500 text-[0.8125rem]">${escapeHTML(p.phone || '—')}</td>
          <td class="py-3.5 px-4 font-mono text-slate-500 text-xs">${escapeHTML(p.date_of_birth || '—')}</td>
          <td class="py-3.5 px-6 font-mono text-slate-400 text-xs">${escapeHTML(p.created_at?.split('T')[0] || '—')}</td>
          <td class="py-3.5 px-6">
            <button onclick="confirmDeletePatient('${escapeHTML(p.id)}')" class="text-[0.6875rem] border border-red-200 text-red-600 py-1 px-2.5 rounded-md bg-white hover:bg-red-50 font-medium transition-colors">Delete</button>
          </td>
        </tr>`;
    }).join('');
  }

  document.getElementById('search')?.addEventListener('input', (e) => {
    const q = (e.target as HTMLInputElement).value.toLowerCase();
    renderPatients(allPatients.filter((p: any) => p.full_name.toLowerCase().includes(q)));
  });

  let patientToDelete: string | null = null;

  (window as any).confirmDeletePatient = (id: string) => {
    patientToDelete = id;
    const modal = document.getElementById('delete-modal');
    if (modal) modal.classList.replace('hidden', 'flex');
  };

  (window as any).closeDeleteModal = () => {
    patientToDelete = null;
    const modal = document.getElementById('delete-modal');
    if (modal) modal.classList.replace('flex', 'hidden');
  };

  (window as any).executeDelete = async () => {
    if (!patientToDelete) return;
    const id = patientToDelete;
    (window as any).closeDeleteModal();
    
    const { error } = await supabase.from('patients').delete().eq('id', id);
    
    if (error) {
      console.error('Delete error:', error);
      const errBanner = document.getElementById('delete-error');
      const errMsg = document.getElementById('delete-error-msg');
      if (errBanner && errMsg) {
        errMsg.textContent = error.message || 'Unknown error occurred.';
        errBanner.classList.replace('hidden', 'flex');
        setTimeout(() => errBanner.classList.replace('flex', 'hidden'), 5000);
      }
    } else {
      allPatients = allPatients.filter((p: any) => p.id !== id);
      const countEl = document.getElementById('total-count');
      if (countEl) countEl.textContent = `${allPatients.length} patients`;
      
      // Re-apply search filter if any
      const searchInput = document.getElementById('search') as HTMLInputElement;
      const q = searchInput ? searchInput.value.toLowerCase() : '';
      renderPatients(allPatients.filter((p: any) => p.full_name.toLowerCase().includes(q)));
    }
  };

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      (window as any).closeDeleteModal();
    }
  });
</script>
