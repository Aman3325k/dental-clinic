---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Sign In" description="Sign in to your SmileCare patient account.">
  <Nav />
  <main class="min-h-screen flex items-center justify-center py-12 px-4" style="background: #F8FAFC;">
    <div class="w-full max-w-md bg-white border border-slate-200 rounded-2xl p-8 shadow-sm">
      <!-- Logo -->
      <div class="text-center mb-6">
        <svg viewBox="0 0 32 32" width="40" height="40" class="mx-auto mb-3">
          <path d="M16 3 C10 3 6 8 6 13 C6 17 8 20 9 23 C10 26 11 30 13 29 C14.5 28 15 25 16 25 C17 25 17.5 28 19 29 C21 30 22 26 23 23 C24 20 26 17 26 13 C26 8 22 3 16 3 Z"
            fill="none" stroke="#0EA5E9" stroke-width="2"/>
        </svg>
        <h1 style="font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 1.5rem; color: #0F172A;">Welcome back</h1>
        <p class="text-sm text-slate-500 mt-1">Sign in to manage your appointments</p>
      </div>

      <!-- Form -->
      <form id="login-form" novalidate>
        <div class="mb-4">
          <label class="block text-sm font-medium text-slate-700 mb-1" for="email">Email address</label>
          <input id="email" type="email" placeholder="your@email.com" required
            class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent" />
        </div>
        <div class="mb-6">
          <label class="block text-sm font-medium text-slate-700 mb-1" for="password">Password</label>
          <div class="relative">
            <input id="password" type="password" placeholder="••••••••" required
              class="w-full border border-slate-200 rounded-lg px-4 py-3 pr-12 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent" />
            <button type="button" id="toggle-password" class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 hover:text-slate-600 transition-colors">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
        </div>
        
        <div id="error-msg" class="hidden mb-4 p-4 bg-red-50 border-l-4 border-red-500 rounded-r-lg text-sm text-red-700 flex items-start gap-3 transition-opacity duration-300">
          <svg class="w-5 h-5 shrink-0 text-red-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <span id="error-text"></span>
        </div>

        <button id="submit-btn" type="submit"
          class="w-full py-3 rounded-lg text-white font-medium transition bg-sky-500 hover:bg-sky-600 btn-press flex items-center justify-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed">
          <span id="submit-text">Sign in</span>
          <svg id="submit-spinner" class="hidden animate-spin w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
        <div class="mt-4 text-center">
          <a href="/forgot-password" class="text-sm text-slate-500 hover:underline focus-visible:outline-sky-500 rounded">Forgot password?</a>
        </div>
      </form>

      <p class="text-center text-sm text-slate-500 mt-6">
        Don't have an account? <a href="/signup" class="text-sky-500 hover:underline">Sign up</a>
      </p>

    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  import { supabase } from '../lib/supabase';
  import { checkAdminRole } from '../lib/utils';

  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorEl = document.getElementById('error-msg') as HTMLDivElement;
  const errorText = document.getElementById('error-text') as HTMLSpanElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('submit-text') as HTMLSpanElement;
  const btnSpinner = document.getElementById('submit-spinner') as HTMLElement;

  const toggleBtn = document.getElementById('toggle-password');
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  toggleBtn?.addEventListener('click', () => {
    if (passwordInput.type === 'password') {
      passwordInput.type = 'text';
      toggleBtn.innerHTML = '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" y1="2" x2="22" y2="22"/></svg>';
    } else {
      passwordInput.type = 'password';
      toggleBtn.innerHTML = '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = passwordInput.value;

    errorEl.classList.add('hidden');
    errorText.textContent = '';
    btn.disabled = true;
    btnText.textContent = 'Signing in...';
    btnSpinner.classList.remove('hidden');

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      console.error('Login error:', error);
      errorText.textContent = 'Incorrect email or password. Please try again.';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btnText.textContent = 'Sign in';
      btnSpinner.classList.add('hidden');
      return;
    }

    // Force the Supabase client to sync the session to its internal state
    // before we make an RLS-protected query
    await supabase.auth.getSession();

    const isAdmin = await checkAdminRole(data.user!.id);
    
    if (isAdmin) {
      window.location.href = '/admin';
    } else {
      window.location.href = '/dashboard';
    }
  });
</script>
