---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Contact Us" description="Get in touch with SmileCare Dental. Find our address, hours, and send us a message.">
  <Nav />
  <main class="max-w-6xl mx-auto px-4 py-16 md:py-24">
    <h1 class="font-['DM_Sans'] font-bold text-[1.875rem] text-slate-900 mb-10">
      Get in touch
    </h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

      <!-- Clinic info -->
      <div class="bg-slate-50 border border-slate-200 rounded-2xl p-8">
        <div class="flex items-start gap-4 mb-6">
          <span class="text-sky-500 mt-0.5 shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </span>
          <div>
            <p class="text-sm font-semibold text-slate-900">Address</p>
            <p class="text-sm text-slate-500 mt-1">123 Main Street, Your City, State</p>
          </div>
        </div>
        <div class="flex items-start gap-4 mb-6">
          <span class="text-sky-500 mt-0.5 shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          </span>
          <div>
            <p class="text-sm font-semibold text-slate-900">Phone</p>
            <p class="text-sm text-slate-500 mt-1">+91 98765 43210</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-sky-500 mt-0.5 shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </span>
          <div>
            <p class="text-sm font-semibold text-slate-900">Hours</p>
            <p class="text-sm text-slate-500 mt-1">Mon–Fri: 9:00 AM – 6:00 PM</p>
            <p class="text-sm text-slate-500">Saturday: 9:00 AM – 2:00 PM</p>
            <p class="text-sm text-slate-500">Sunday: Closed</p>
          </div>
        </div>
      </div>

      <!-- Contact form -->
      <div>
        <form id="contact-form" novalidate>
          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 mb-1" for="name">Your name</label>
            <input id="name" name="name" type="text" placeholder="Aman Pradhan" required
              class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-sky-500" />
          </div>
          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 mb-1" for="contact-email">Email address</label>
            <input id="contact-email" name="email" type="email" placeholder="your@email.com" required
              class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-sky-500" />
          </div>
          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 mb-1" for="contact-phone">Phone (optional)</label>
            <input id="contact-phone" name="phone" type="tel" placeholder="+91 98765 43210"
              class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-sky-500" />
          </div>
          <div class="mb-6">
            <label class="block text-sm font-medium text-slate-700 mb-1" for="message">Message</label>
            <textarea id="message" name="message" rows="4" placeholder="How can we help you?" required
              class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-sky-500 resize-none"></textarea>
          </div>
          
          <p id="contact-error" class="text-red-500 text-sm mb-4 hidden">Please fill in all required fields correctly.</p>
          <p id="contact-success" class="text-emerald-700 bg-emerald-50 border border-emerald-200 p-4 rounded-xl text-sm mb-4 hidden flex items-start gap-3" style="animation: slide-down 0.4s ease-out forwards;">
            <svg class="w-5 h-5 shrink-0 text-emerald-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <span>Your message has been sent successfully. We'll be in touch soon!</span>
          </p>
          
          <div class="flex items-center gap-4">
            <button id="contact-submit" type="submit"
              class="flex-1 py-3 rounded-lg text-white font-medium transition bg-sky-500 hover:bg-sky-600 btn-press disabled:opacity-50 disabled:cursor-not-allowed">
              Send message
            </button>
            <span class="text-xs text-slate-400 font-medium whitespace-nowrap">(Opens your email app)</span>
          </div>
        </form>
      </div>

    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;
  const errorMsg = document.getElementById('contact-error') as HTMLParagraphElement;
  const successMsg = document.getElementById('contact-success') as HTMLParagraphElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // Reset states
    errorMsg.classList.add('hidden');
    successMsg.classList.add('hidden');
    
    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('contact-email') as HTMLInputElement).value.trim();
    const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();

    // Basic validation
    if (!name || !email || !message || !email.includes('@')) {
      errorMsg.classList.remove('hidden');
      return;
    }

    const phone = (document.getElementById('contact-phone') as HTMLInputElement).value.trim();
    
    const subject = encodeURIComponent(`New Contact Form Submission from ${name}`);
    const body = encodeURIComponent(`Name: ${name}\nEmail: ${email}\nPhone: ${phone || 'Not provided'}\n\nMessage:\n${message}`);
    
    window.location.href = `mailto:admin@dental.com?subject=${subject}&body=${body}`;

    setTimeout(() => {
      form.reset();
      successMsg.classList.remove('hidden');
    }, 500);
  });
</script>
