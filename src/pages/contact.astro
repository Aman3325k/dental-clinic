---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Contact Us" description="Get in touch with SmileCare Dental. Find our address, hours, and send us a message.">
  <Nav />
  <main class="max-w-6xl mx-auto px-4 py-16 md:py-24">
    <h1 style="font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 1.875rem; color: #0F172A; margin-bottom: 2.5rem;">
      Get in touch
    </h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

      <!-- Clinic info -->
      <div class="bg-slate-50 border border-slate-200 rounded-2xl p-8">
        <div class="flex items-start gap-3 mb-5">
          <span class="text-xl">📍</span>
          <div>
            <p class="text-sm font-medium text-slate-900">Address</p>
            <p class="text-sm text-slate-500 mt-0.5">123 Main Street, Your City, State</p>
          </div>
        </div>
        <div class="flex items-start gap-3 mb-5">
          <span class="text-xl">📞</span>
          <div>
            <p class="text-sm font-medium text-slate-900">Phone</p>
            <p class="text-sm text-slate-500 mt-0.5">+91 98765 43210</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-xl">🕐</span>
          <div>
            <p class="text-sm font-medium text-slate-900">Hours</p>
            <p class="text-sm text-slate-500 mt-0.5">Mon–Fri: 9:00 AM – 6:00 PM</p>
            <p class="text-sm text-slate-500">Saturday: 9:00 AM – 2:00 PM</p>
            <p class="text-sm text-slate-500">Sunday: Closed</p>
          </div>
        </div>
      </div>

      <!-- Contact form -->
      <div>
        <form id="contact-form" action="https://formspree.io/f/REPLACE_ME" method="POST">
          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 mb-1" for="name">Your name</label>
            <input id="name" name="name" type="text" placeholder="Aman Pradhan" required
              class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:border-transparent" />
          </div>
          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 mb-1" for="contact-email">Email address</label>
            <input id="contact-email" name="email" type="email" placeholder="your@email.com" required
              class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:border-transparent" />
          </div>
          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 mb-1" for="contact-phone">Phone (optional)</label>
            <input id="contact-phone" name="phone" type="tel" placeholder="+91 98765 43210"
              class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:border-transparent" />
          </div>
          <div class="mb-6">
            <label class="block text-sm font-medium text-slate-700 mb-1" for="message">Message</label>
            <textarea id="message" name="message" rows="4" placeholder="How can we help you?" required
              class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:border-transparent resize-none"></textarea>
          </div>
          <button type="submit"
            class="w-full py-3 rounded-lg text-white font-medium transition"
            style="background: #0EA5E9;">
            Send message
          </button>
        </form>
      </div>

    </div>
  </main>
  <Footer />
</BaseLayout>
