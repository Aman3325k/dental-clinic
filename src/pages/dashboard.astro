---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Your Dashboard" description="Manage your dental appointments.">
  <div class="min-h-screen flex flex-col bg-slate-50">

    <!-- Top Nav -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="font-['DM_Sans'] font-extrabold text-xl text-sky-500 no-underline">
          SmileCare
        </a>
        <div class="flex items-center gap-4">
          <span id="user-email" class="text-sm text-slate-500 hidden md:block"></span>
          <button id="signout-btn" aria-label="Sign out" class="text-sm text-slate-500 hover:text-red-500 transition">Sign out</button>
        </div>
      </div>
    </header>

    <!-- Main -->
    <main class="max-w-6xl mx-auto px-4 py-10 w-full flex-1">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">

        <!-- Sidebar: Profile Card -->
        <aside class="md:col-span-1">
          <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
            <div id="avatar" class="w-16 h-16 rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-4 bg-slate-100 text-slate-400 font-['DM_Sans'] transition-colors duration-300">
            </div>
            <p id="profile-name" class="text-center font-semibold text-slate-900 font-['DM_Sans']">Loading...</p>
            <p id="profile-email" class="text-center text-sm text-slate-500 mt-1"></p>
            <hr class="my-4 border-slate-100" />
            <div class="text-center">
              <p class="text-xs text-slate-400 uppercase tracking-wider mb-1">Total appointments</p>
              <p id="total-count" class="text-2xl font-bold font-['DM_Sans'] text-sky-500">—</p>
            </div>
            <div class="text-center mt-4">
              <p class="text-xs text-slate-400 uppercase tracking-wider mb-1">Next visit</p>
              <p id="next-visit" class="text-sm font-medium text-slate-700 font-mono">—</p>
            </div>
          </div>
        </aside>

        <!-- Main: Appointments -->
        <div class="md:col-span-3">
          <div class="flex items-center justify-between mb-6">
            <h1 class="font-['DM_Sans'] font-bold text-2xl text-slate-900">
              Your Appointments
            </h1>
            <a href="/book" class="px-5 py-2 rounded-lg text-white text-sm font-medium transition bg-sky-500 hover:bg-sky-600">
              + Book New
            </a>
          </div>

          <!-- Tabs -->
          <div class="flex gap-1 mb-6 border-b border-slate-200">
            <button id="tab-upcoming" onclick="showTab('upcoming')"
              class="px-4 py-2 text-sm font-medium border-b-2 transition-colors duration-300 border-sky-500 text-sky-500">
              Upcoming
            </button>
            <button id="tab-past" onclick="showTab('past')"
              class="px-4 py-2 text-sm font-medium border-b-2 transition-colors duration-300 border-transparent text-slate-500 hover:text-slate-700">
              Past
            </button>
          </div>

          <!-- Success message -->
          <div id="booked-msg" class="hidden mb-4 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-700 text-sm">
            ✅ Appointment booked successfully! We'll confirm your slot shortly.
          </div>

          <!-- Appointment lists -->
          <div id="upcoming-list"><p class="text-slate-400 text-sm">Loading...</p></div>
          <div id="past-list" class="hidden"><p class="text-slate-400 text-sm">Loading...</p></div>
          <p id="appointments-error" class="text-red-500 text-sm hidden"></p>
        </div>

      </div>
    </main>

    <Footer />
  </div>

  <!-- Cancel Confirmation Modal -->
  <div id="cancel-modal" class="fixed inset-0 z-[200] flex items-center justify-center hidden" role="dialog" aria-modal="true" aria-labelledby="cancel-modal-title">
    <!-- Overlay -->
    <div id="cancel-modal-overlay" class="absolute inset-0 bg-slate-900/50"></div>
    <!-- Card -->
    <div class="relative bg-white rounded-xl shadow-xl p-6 w-full max-w-sm mx-4 font-['DM_Sans']">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 6v4M10 14h.01M19 10a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke="#EF4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h2 id="cancel-modal-title" class="font-bold text-slate-900 text-base">Cancel appointment?</h2>
      </div>
      <p class="text-sm text-slate-500 mb-5 pl-[3.25rem]">This action cannot be undone. The appointment will be marked as cancelled.</p>
      <!-- Inline error inside modal -->
      <div id="cancel-modal-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"></div>
      <div class="flex gap-3">
        <button id="cancel-modal-back" class="flex-1 py-2.5 rounded-lg border border-slate-200 text-slate-700 text-sm font-medium hover:bg-slate-50 transition">
          Go back
        </button>
        <button id="cancel-modal-confirm" class="flex-1 py-2.5 rounded-lg bg-red-500 text-white text-sm font-medium hover:bg-red-600 transition disabled:opacity-50 disabled:cursor-not-allowed">
          Yes, cancel appointment
        </button>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { supabase } from '../lib/supabase';
  import { checkAdminRole, escapeHTML } from '../lib/utils';

  // Auth guard
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    window.location.href = '/login';
  } else {
    const isAdmin = await checkAdminRole(session.user.id);
    if (isAdmin) {
      window.location.href = '/admin';
    } else {
      initDashboard();
    }
  }

  function formatDate(iso: string): string {
    const [year, month, day] = iso.split('-').map(Number);
    const d = new Date(year, month - 1, day);
    return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
  }

  async function initDashboard() {
    const user = session!.user;

    // Show user info
    const emailEl = document.getElementById('user-email');
    const profileName = document.getElementById('profile-name');
    const profileEmail = document.getElementById('profile-email');
    const avatar = document.getElementById('avatar');

    if (emailEl) emailEl.textContent = user.email || '';
    if (profileEmail) profileEmail.textContent = user.email || '';

    // Load patient profile
    const { data: patient } = await supabase
      .from('patients')
      .select('full_name')
      .eq('id', user.id)
      .single();

    if (patient && profileName) {
      profileName.textContent = patient.full_name;
      if (avatar) {
        const names = patient.full_name.trim().split(/\s+/);
        let initials = names[0].charAt(0).toUpperCase();
        if (names.length > 1) {
          initials += names[names.length - 1].charAt(0).toUpperCase();
        }
        avatar.textContent = initials;
        avatar.classList.remove('bg-slate-100', 'text-slate-400');
        avatar.classList.add('bg-sky-100', 'text-sky-500');
      }
    }

    // Show booked success message
    if (window.location.search.includes('booked=true')) {
      document.getElementById('booked-msg')?.classList.remove('hidden');
      window.history.replaceState({}, document.title, window.location.pathname);
    }

    // Load appointments
    const { data: appointments, error } = await supabase
      .from('appointments')
      .select('*')
      .eq('patient_id', user.id)
      .order('appointment_date', { ascending: true });

    if (error) {
      const errEl = document.getElementById('appointments-error');
      if (errEl) {
        errEl.textContent = 'Failed to load appointments.';
        errEl.classList.remove('hidden');
      }
    } else {
      const now = new Date().toISOString().split('T')[0];
      const upcoming = appointments.filter(a => a.appointment_date >= now);
      const past = appointments.filter(a => a.appointment_date < now);

      const totalEl = document.getElementById('total-count');
      if (totalEl) totalEl.textContent = String(appointments.length);

      const nextEl = document.getElementById('next-visit');
      if (nextEl && upcoming.length > 0) {
        nextEl.textContent = formatDate(upcoming[0].appointment_date);
      } else if (nextEl) {
        nextEl.textContent = 'None scheduled';
      }

      renderList('upcoming-list', upcoming);
      renderList('past-list', past);
    }
  }

  function renderList(id: string, items: any[]) {
    const el = document.getElementById(id);
    if (!el) return;
    if (items.length === 0) {
      el.innerHTML = `
        <div class="text-center py-12 px-4 border border-slate-200 border-dashed rounded-xl bg-white">
          <svg class="mx-auto w-12 h-12 text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          <h3 class="font-['DM_Sans'] font-semibold text-slate-900 mb-1">No appointments yet</h3>
          <p class="text-slate-500 text-sm mb-5">You don't have any appointments in this list.</p>
          <a href="/book" class="inline-block px-5 py-2.5 rounded-lg text-white font-medium transition bg-sky-500 hover:bg-sky-600 btn-press text-sm">
            Book your first appointment
          </a>
        </div>
      `;
      return;
    }
    el.innerHTML = items.map(a => {
      let bClass = '';
      if (a.status === 'pending') bClass = 'border-l-4 border-l-amber-500';
      else if (a.status === 'confirmed') bClass = 'border-l-4 border-l-emerald-500';
      else if (a.status === 'cancelled') bClass = 'border-l-4 border-l-slate-400';
      
      return `
      <div class="bg-white border border-slate-200 rounded-xl p-4 mb-3 ${bClass} transition-shadow hover:shadow-sm">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="font-medium text-slate-900 font-['DM_Sans']">${escapeHTML(a.treatment_type)}</p>
            <p class="text-sm text-slate-500 mt-1 font-mono">${formatDate(a.appointment_date)} at ${escapeHTML(a.appointment_time)}</p>
            ${a.notes ? `<p class="text-sm text-slate-400 italic mt-1">${escapeHTML(a.notes)}</p>` : ''}
          </div>
          <div class="flex flex-col items-end gap-2 shrink-0">
            <span class="status-${escapeHTML(a.status)}">${escapeHTML(a.status)}</span>
            ${id === 'upcoming-list' && (a.status === 'pending' || a.status === 'confirmed') ?
              `<button onclick="openCancelModal('${a.id}')" class="text-xs px-2.5 py-1 rounded-md border border-red-200 text-red-600 hover:bg-red-50 transition font-medium btn-press">Cancel</button>` : ''}
          </div>
        </div>
      </div>
      `;
    }).join('');
  }

  // Tab switching
  (window as any).showTab = (tab: string) => {
    const upcoming = document.getElementById('upcoming-list');
    const past = document.getElementById('past-list');
    const tabUpcoming = document.getElementById('tab-upcoming');
    const tabPast = document.getElementById('tab-past');

    if (tab === 'upcoming') {
      upcoming?.classList.remove('hidden');
      past?.classList.add('hidden');
      
      tabUpcoming?.classList.remove('border-transparent', 'text-slate-500', 'hover:text-slate-700');
      tabUpcoming?.classList.add('border-sky-500', 'text-sky-500');
      
      tabPast?.classList.remove('border-sky-500', 'text-sky-500');
      tabPast?.classList.add('border-transparent', 'text-slate-500', 'hover:text-slate-700');
    } else {
      upcoming?.classList.add('hidden');
      past?.classList.remove('hidden');
      
      tabUpcoming?.classList.remove('border-sky-500', 'text-sky-500');
      tabUpcoming?.classList.add('border-transparent', 'text-slate-500', 'hover:text-slate-700');
      
      tabPast?.classList.remove('border-transparent', 'text-slate-500', 'hover:text-slate-700');
      tabPast?.classList.add('border-sky-500', 'text-sky-500');
    }
  };

  // --- Cancel Modal Logic ---
  let pendingCancelId: string | null = null;

  (window as any).openCancelModal = (id: string) => {
    pendingCancelId = id;
    const modal = document.getElementById('cancel-modal');
    const errorEl = document.getElementById('cancel-modal-error');
    if (errorEl) errorEl.classList.add('hidden');
    modal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  };

  function closeModal() {
    const modal = document.getElementById('cancel-modal');
    modal?.classList.add('hidden');
    document.body.style.overflow = '';
    pendingCancelId = null;
  }

  document.getElementById('cancel-modal-back')?.addEventListener('click', closeModal);
  document.getElementById('cancel-modal-overlay')?.addEventListener('click', closeModal);

  document.getElementById('cancel-modal-confirm')?.addEventListener('click', async () => {
    if (!pendingCancelId) return;
    
    const confirmBtn = document.getElementById('cancel-modal-confirm') as HTMLButtonElement;
    const errorEl = document.getElementById('cancel-modal-error');
    confirmBtn.disabled = true;
    confirmBtn.textContent = 'Cancelling...';
    if (errorEl) errorEl.classList.add('hidden');

    const { error } = await supabase
      .from('appointments')
      .update({ status: 'cancelled' })
      .eq('id', pendingCancelId);

    if (error) {
      console.error('Cancel error:', error);
      if (errorEl) {
        errorEl.textContent = 'Failed to cancel. Please try again.';
        errorEl.classList.remove('hidden');
      }
      confirmBtn.disabled = false;
      confirmBtn.textContent = 'Yes, cancel appointment';
    } else {
      closeModal();
      window.location.reload();
    }
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Sign out
  document.getElementById('signout-btn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });
</script>
