---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ToothHero from '../components/ToothHero.astro';
---
<BaseLayout title="Book Dental Appointments Online" description="SmileCare Dental — book appointments, view records, and manage your dental health online.">
  <Nav />
  <main>
  <!-- HERO -->
  <section class="max-w-6xl mx-auto px-4 py-16 md:py-24 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    <div>
      <p class="text-sm font-medium uppercase tracking-wider mb-4 text-sky-500">Trusted Dental Care</p>
      <h1 class="font-['DM_Sans'] font-extrabold text-[clamp(2rem,5vw,3rem)] text-slate-900 leading-[1.15]">
        Healthy teeth,<br/>booked in minutes.
      </h1>
      <p class="mt-4 text-lg text-slate-500 max-w-md">
        Book your next dental appointment online — no phone calls, no waiting.
      </p>
      <div class="flex flex-wrap gap-4 mt-8">
        <a href="/signup" class="px-6 py-3 rounded-lg text-white font-medium transition bg-sky-500 hover:bg-sky-600 btn-press cta-book-btn">
          Book an Appointment
        </a>
        <a href="/contact" aria-label="Learn more about SmileCare Dental" class="px-6 py-3 rounded-lg font-medium border border-slate-200 text-slate-700 hover:bg-slate-50 transition btn-press">
          Learn More
        </a>
      </div>
      <p class="mt-6 text-xs text-slate-400">
        ✓ Free first consultation &nbsp;&nbsp; ✓ Same-day bookings &nbsp;&nbsp; ✓ Patient records online
      </p>
    </div>
    <ToothHero />
  </section>

  <!-- STATS BAR -->
  <section class="bg-slate-50 border-y border-slate-200 py-8">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {[
        { number: '2,400+', label: 'Patients treated', icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-sky-400"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' },
        { number: '15 yrs', label: 'Experience', icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-sky-400"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' },
        { number: '98%',    label: 'Satisfaction rate', icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-sky-400"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>' },
        { number: '6',      label: 'Dental specialists', icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-sky-400"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>' },
      ].map((stat, i) => (
        <div class={i < 3 ? "md:border-r md:border-slate-200" : ""}>
          <div set:html={stat.icon} />
          <p class="font-['DM_Sans'] font-extrabold text-3xl text-sky-500">{stat.number}</p>
          <p class="text-sm text-slate-500 mt-1">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- SERVICES -->
  <section class="max-w-6xl mx-auto px-4 py-16 md:py-24">
    <h2 class="font-['DM_Sans'] font-bold text-3xl text-slate-900 text-center mb-10">
      What we treat
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      {[
        { icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sky-500"><path d="M2 12h20"/><path d="M20 12v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8"/><path d="M4 12V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8"/></svg>', name: 'General Checkup',  desc: 'Routine exams to keep your teeth healthy.' },
        { icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sky-500"><path d="m9.06 11.9 8.07-8.06a2.85 2.85 0 1 1 4.03 4.03l-8.06 8.08"/><path d="M7.07 14.94c-1.66 0-3 1.35-3 3.02 0 1.33-2.5 1.52-2 2.02 1.08 1.1 2.49 2.02 4 2.02 2.2 0 4-1.8 4-4.04a3.01 3.01 0 0 0-3-3.02z"/></svg>', name: 'Teeth Cleaning',    desc: 'Professional cleaning to remove plaque and tartar.' },
        { icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sky-500"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>', name: 'Whitening',         desc: 'Safe whitening for a noticeably brighter smile.' },
        { icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sky-500"><path d="m8 10 3 3-3 3"/><path d="m16 10-3 3 3 3"/><path d="M22 12c0 5.523-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2s10 4.477 10 10z"/></svg>', name: 'Fillings',          desc: 'Restore cavities quickly with tooth-colored fillings.' },
        { icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sky-500"><path d="M21 3v6h-6"/><path d="M3 21v-6h6"/><path d="M12 9a3 3 0 0 0 0 6"/><path d="M15.4 6.2A9 9 0 1 0 12 21a8.9 8.9 0 0 0 3.8-1"/></svg>', name: 'Extraction',        desc: 'Safe removal of damaged or impacted teeth.' },
        { icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sky-500"><path d="M4 22h14a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v4"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m3 15 4 4 4-4"/><path d="M7 11v8"/></svg>', name: 'Root Canal',        desc: 'Relieve pain and save your natural tooth.' },
      ].map(service => (
        <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300">
          <div class="mb-4" set:html={service.icon} />
          <h3 class="font-['DM_Sans'] font-semibold text-slate-900 text-base mb-2">{service.name}</h3>
          <p class="text-sm text-slate-500">{service.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="bg-slate-50 border-y border-slate-200 py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-['DM_Sans'] font-bold text-3xl text-slate-900 text-center mb-12">
        How to book
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { n: '1', title: 'Create your account', desc: 'Sign up in under a minute with your email.' },
          { n: '2', title: 'Pick a date & treatment', desc: 'Choose your preferred time and what you need.' },
          { n: '3', title: 'We confirm your slot', desc: 'You get confirmation and your appointment is set.' },
        ].map(step => (
          <div class="text-center">
            <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold mx-auto mb-4 bg-sky-500 font-['DM_Sans']">
              {step.n}
            </div>
            <h3 class="font-['DM_Sans'] font-semibold text-slate-900 mb-2">{step.title}</h3>
            <p class="text-sm text-slate-500">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="max-w-4xl mx-auto px-4 py-16 md:py-24">
    <div class="rounded-3xl p-10 md:p-14 text-center bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-sky-400 via-sky-500 to-sky-700 shadow-lg">
      <h2 class="font-['DM_Sans'] font-extrabold text-3xl text-white mb-3">
        Ready to book your appointment?
      </h2>
      <p class="text-sky-100 text-lg mb-8">It takes under 2 minutes.</p>
      <a href="/signup" class="inline-block px-8 py-4 rounded-lg font-semibold transition bg-white text-sky-600 hover:bg-slate-50 btn-press cta-book-btn">
        Book Now
      </a>
    </div>
  </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  import { supabase } from '../lib/supabase';
  supabase.auth.getSession().then(({ data }) => {
    if (data?.session) {
      document.querySelectorAll('.cta-book-btn').forEach((btn) => {
        (btn as HTMLAnchorElement).href = '/book';
      });
    }
  });
</script>
