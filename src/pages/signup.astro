---
// -- Run this in Supabase SQL Editor:
// -- CREATE POLICY "Users can insert own profile"
// -- ON patients FOR INSERT
// -- WITH CHECK (auth.uid() = id);

import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Create Account" description="Create your SmileCare patient account and book dental appointments online.">
  <Nav />
  <main class="min-h-screen flex items-center justify-center py-12 px-4" style="background: #F8FAFC;">
    <div class="w-full max-w-lg bg-white border border-slate-200 rounded-2xl p-8 shadow-sm">
      <div class="text-center mb-6">
        <svg viewBox="0 0 32 32" width="40" height="40" class="mx-auto mb-3">
          <path d="M16 3 C10 3 6 8 6 13 C6 17 8 20 9 23 C10 26 11 30 13 29 C14.5 28 15 25 16 25 C17 25 17.5 28 19 29 C21 30 22 26 23 23 C24 20 26 17 26 13 C26 8 22 3 16 3 Z"
            fill="none" stroke="#0EA5E9" stroke-width="2"/>
        </svg>
        <h1 style="font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 1.5rem; color: #0F172A;">Create your account</h1>
        <p class="text-sm text-slate-500 mt-1">Book and manage dental appointments online</p>
      </div>

      <form id="signup-form" novalidate>
        <div class="mb-4">
          <label class="block text-sm font-medium text-slate-700 mb-1" for="full-name">Full name</label>
          <input id="full-name" type="text" placeholder="Aman Pradhan" required
            class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:border-transparent" />
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-slate-700 mb-1" for="email">Email address</label>
          <input id="email" type="email" placeholder="your@email.com" required
            class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:border-transparent" />
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-slate-700 mb-1" for="phone">Phone number</label>
          <div class="flex border border-slate-200 rounded-lg focus-within:ring-2 focus-within:ring-sky-500 bg-white overflow-hidden">
            <select id="phone-country" class="px-3 py-3 text-slate-900 text-sm focus:outline-none bg-white border-r border-slate-200" style="min-width: 110px;">
              <option value="+91">🇮🇳 +91</option>
              <option value="+1">🇺🇸 +1</option>
              <option value="+44">🇬🇧 +44</option>
              <option value="+61">🇦🇺 +61</option>
              <option value="+971">🇦🇪 +971</option>
              <option value="+65">🇸🇬 +65</option>
              <option value="+60">🇲🇾 +60</option>
              <option value="+880">🇧🇩 +880</option>
              <option value="+92">🇵🇰 +92</option>
              <option value="+977">🇳🇵 +977</option>
            </select>
            <input id="phone" type="tel" placeholder="98765 43210" required
              class="flex-1 px-4 py-3 text-slate-900 text-sm focus:outline-none bg-transparent" />
          </div>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-slate-700 mb-1" for="dob">Date of birth</label>
          <input id="dob" type="date" required
            class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:border-transparent" />
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-slate-700 mb-1" for="password">Password</label>
          <div class="relative">
            <input id="password" type="password" placeholder="Min. 8 characters" required minlength="8"
              class="w-full border border-slate-200 rounded-lg px-4 py-3 pr-12 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent" />
            <button type="button" id="toggle-password" class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 hover:text-slate-600 transition-colors">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </button>
          </div>
        </div>
        <div class="mb-2">
          <label class="block text-sm font-medium text-slate-700 mb-1" for="confirm-password">Confirm password</label>
          <div class="relative">
            <input id="confirm-password" type="password" placeholder="••••••••" required
              class="w-full border border-slate-200 rounded-lg px-4 py-3 pr-12 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent" />
            <button type="button" id="toggle-confirm" class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 hover:text-slate-600 transition-colors">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </button>
          </div>
        </div>
        
        <div class="mb-6 flex flex-col gap-1 px-1">
          <div class="flex items-center gap-2 text-xs text-slate-400 transition-colors" id="val-length">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle></svg>
            <span>Min. 8 characters</span>
          </div>
          <div class="flex items-center gap-2 text-xs text-slate-400 transition-colors" id="val-match">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle></svg>
            <span>Passwords match</span>
          </div>
        </div>

        <div id="error-msg" class="hidden mb-4 p-4 bg-red-50 border-l-4 border-red-500 rounded-r-lg text-sm text-red-700 flex items-start gap-3 transition-opacity duration-300">
          <svg class="w-5 h-5 shrink-0 text-red-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <span id="error-text"></span>
        </div>
        
        <button id="submit-btn" type="submit"
          class="w-full py-3 rounded-lg text-white font-medium transition bg-sky-500 hover:bg-sky-600 btn-press flex items-center justify-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed">
          <span id="submit-text">Create account</span>
          <svg id="submit-spinner" class="hidden animate-spin w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
      </form>

      <p class="text-center text-sm text-slate-500 mt-6">
        Already have an account? <a href="/login" class="text-sky-500 hover:underline">Sign in</a>
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  import { supabase } from '../lib/supabase';

  const form = document.getElementById('signup-form') as HTMLFormElement;
  const errorEl = document.getElementById('error-msg') as HTMLDivElement;
  const errorText = document.getElementById('error-text') as HTMLSpanElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('submit-text') as HTMLSpanElement;
  const btnSpinner = document.getElementById('submit-spinner') as HTMLElement;

  const pwdInput = document.getElementById('password') as HTMLInputElement;
  const confirmInput = document.getElementById('confirm-password') as HTMLInputElement;
  const valLength = document.getElementById('val-length');
  const valMatch = document.getElementById('val-match');

  const checkIcon = '<svg class="w-3.5 h-3.5 shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>';
  const crossIcon = '<svg class="w-3.5 h-3.5 shrink-0 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>';
  const circleIcon = '<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle></svg>';

  function updateValidation() {
    const pwd = pwdInput.value;
    const conf = confirmInput.value;

    if (valLength) {
      if (pwd.length === 0) {
        valLength.innerHTML = `${circleIcon} <span>Min. 8 characters</span>`;
        valLength.className = 'flex items-center gap-2 text-xs text-slate-400 transition-colors';
      } else if (pwd.length >= 8) {
        valLength.innerHTML = `${checkIcon} <span class="text-slate-600">Min. 8 characters</span>`;
        valLength.className = 'flex items-center gap-2 text-xs transition-colors';
      } else {
        valLength.innerHTML = `${crossIcon} <span class="text-red-500">Min. 8 characters</span>`;
        valLength.className = 'flex items-center gap-2 text-xs transition-colors';
      }
    }

    if (valMatch) {
      if (conf.length === 0) {
        valMatch.innerHTML = `${circleIcon} <span>Passwords match</span>`;
        valMatch.className = 'flex items-center gap-2 text-xs text-slate-400 transition-colors';
      } else if (pwd === conf) {
        valMatch.innerHTML = `${checkIcon} <span class="text-slate-600">Passwords match</span>`;
        valMatch.className = 'flex items-center gap-2 text-xs transition-colors';
      } else {
        valMatch.innerHTML = `${crossIcon} <span class="text-red-500">Passwords match</span>`;
        valMatch.className = 'flex items-center gap-2 text-xs transition-colors';
      }
    }
  }

  pwdInput.addEventListener('input', updateValidation);
  confirmInput.addEventListener('input', updateValidation);

  const setupToggle = (inputId: string, btnId: string) => {
    const toggle = document.getElementById(btnId);
    const input = document.getElementById(inputId) as HTMLInputElement;
    toggle?.addEventListener('click', () => {
      if (input.type === 'password') {
        input.type = 'text';
        toggle.innerHTML = '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" y1="2" x2="22" y2="22"/></svg>';
      } else {
        input.type = 'password';
        toggle.innerHTML = '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
      }
    });
  };
  setupToggle('password', 'toggle-password');
  setupToggle('confirm-password', 'toggle-confirm');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fullName = (document.getElementById('full-name') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const phoneCountry = (document.getElementById('phone-country') as HTMLSelectElement).value;
    const phoneNumber = (document.getElementById('phone') as HTMLInputElement).value;
    const phone = phoneNumber ? `${phoneCountry} ${phoneNumber}` : '';
    const dob = (document.getElementById('dob') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirm-password') as HTMLInputElement).value;

    errorEl.classList.add('hidden');
    errorText.textContent = '';

    if (password !== confirmPassword) {
      errorText.textContent = 'Passwords do not match.';
      errorEl.classList.remove('hidden');
      return;
    }
    if (password.length < 8) {
      errorText.textContent = 'Password must be at least 8 characters.';
      errorEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    btnText.textContent = 'Creating account...';
    btnSpinner.classList.remove('hidden');

    const { data: authData, error: authError } = await supabase.auth.signUp({ 
      email, 
      password,
      options: {
        data: {
          full_name: fullName,
          phone: phone,
          date_of_birth: dob || null,
        }
      }
    });

    if (authError) {
      console.error('Signup auth error:', authError);
      errorText.textContent = authError.message;
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btnText.textContent = 'Create account';
      btnSpinner.classList.add('hidden');
      return;
    }

    window.location.href = '/dashboard';
  });
</script>
