---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Book Appointment" description="Book your dental appointment online.">
  <Nav />
  <main class="max-w-2xl mx-auto px-4 py-12">

    <!-- Progress indicator -->
    <div class="flex items-center gap-3 mb-10">
      <div id="step1-indicator" class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold text-white" style="background: #0EA5E9; font-family: 'DM Sans', sans-serif;">1</div>
      <div class="text-sm font-medium" id="step1-label" style="color: #0EA5E9;">Details</div>
      <div class="flex-1 h-px bg-slate-200 mx-2"></div>
      <div id="step2-indicator" class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold border-2 border-slate-200 text-slate-400" style="font-family: 'DM Sans', sans-serif;">2</div>
      <div class="text-sm font-medium text-slate-400" id="step2-label">Confirm</div>
    </div>

    <h1 style="font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 1.875rem; color: #0F172A; margin-bottom: 0.5rem;">
      Book an appointment
    </h1>
    <p class="text-slate-500 mb-8">Fill in the details and we'll confirm your slot.</p>

    <!-- Step 1 -->
    <div id="step1">
      <div class="mb-5">
        <label class="block text-sm font-medium text-slate-700 mb-1" for="treatment">Treatment type</label>
        <select id="treatment" class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:border-transparent bg-white">
          <option value="">Select a treatment</option>
          <option>General Checkup</option>
          <option>Teeth Cleaning</option>
          <option>Whitening</option>
          <option>Filling</option>
          <option>Extraction</option>
          <option>Root Canal</option>
          <option>Other</option>
        </select>
      </div>
      <div class="mb-5">
        <label class="block text-sm font-medium text-slate-700 mb-1" for="appt-date">Preferred date</label>
        <input id="appt-date" type="date" class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:border-transparent" />
      </div>
      <div class="mb-5">
        <label class="block text-sm font-medium text-slate-700 mb-1" for="appt-time">Preferred time</label>
        <select id="appt-time" class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:border-transparent bg-white">
          <option value="">Select a time</option>
          <option>09:00</option><option>09:30</option>
          <option>10:00</option><option>10:30</option>
          <option>11:00</option><option>11:30</option>
          <option>12:00</option><option>12:30</option>
          <option>13:00</option><option>13:30</option>
          <option>14:00</option><option>14:30</option>
          <option>15:00</option><option>15:30</option>
          <option>16:00</option><option>16:30</option>
          <option>17:00</option><option>17:30</option>
        </select>
      </div>
      <div class="mb-6">
        <label class="block text-sm font-medium text-slate-700 mb-1" for="notes">Notes (optional)</label>
        <textarea id="notes" rows="3" placeholder="Anything the dentist should know?"
          class="w-full border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:border-transparent resize-none"></textarea>
      </div>
      <p id="step1-error" class="text-red-500 text-sm mb-4 hidden"></p>
      <button id="next-btn" class="w-full py-3 rounded-lg text-white font-medium transition" style="background: #0EA5E9;">
        Next →
      </button>
    </div>

    <!-- Step 2 -->
    <div id="step2" class="hidden">
      <div class="bg-white border border-slate-200 rounded-2xl p-6 mb-6">
        <h2 style="font-family: 'DM Sans', sans-serif; font-weight: 600; color: #0F172A; margin-bottom: 1rem;">Appointment summary</h2>
        <div class="space-y-3">
          <div class="flex justify-between text-sm">
            <span class="text-slate-500">Treatment</span>
            <span id="summary-treatment" class="font-medium text-slate-900"></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-slate-500">Date</span>
            <span id="summary-date" class="font-medium text-slate-900" style="font-family: 'JetBrains Mono', monospace;"></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-slate-500">Time</span>
            <span id="summary-time" class="font-medium text-slate-900" style="font-family: 'JetBrains Mono', monospace;"></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-slate-500">Notes</span>
            <span id="summary-notes" class="font-medium text-slate-900 text-right max-w-xs"></span>
          </div>
        </div>
      </div>
      <p id="step2-error" class="text-red-500 text-sm mb-4 hidden"></p>
      <div class="flex gap-3">
        <button id="back-btn" class="flex-1 py-3 rounded-lg font-medium border border-slate-200 text-slate-700 hover:bg-slate-50 transition">
          ← Back
        </button>
        <button id="confirm-btn" class="flex-1 py-3 rounded-lg text-white font-medium transition" style="background: #0EA5E9;">
          Confirm Booking
        </button>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>

<script>
  import { supabase } from '../lib/supabase';

  // Auth guard
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    window.location.href = '/login';
  }

  let formData: Record<string, string> = {};

  // Set min date to today
  const dateInput = document.getElementById('appt-date') as HTMLInputElement;
  if (dateInput) dateInput.min = new Date().toISOString().split('T')[0];

  // Step 1 → Step 2
  document.getElementById('next-btn')?.addEventListener('click', () => {
    const treatment = (document.getElementById('treatment') as HTMLSelectElement).value;
    const date = (document.getElementById('appt-date') as HTMLInputElement).value;
    const time = (document.getElementById('appt-time') as HTMLSelectElement).value;
    const notes = (document.getElementById('notes') as HTMLTextAreaElement).value;
    const errorEl = document.getElementById('step1-error') as HTMLParagraphElement;

    errorEl.classList.add('hidden');

    if (!treatment || !date || !time) {
      errorEl.textContent = 'Please fill in all required fields.';
      errorEl.classList.remove('hidden');
      return;
    }

    formData = { treatment_type: treatment, appointment_date: date, appointment_time: time, notes };

    (document.getElementById('summary-treatment') as HTMLElement).textContent = treatment;
    (document.getElementById('summary-date') as HTMLElement).textContent = date;
    (document.getElementById('summary-time') as HTMLElement).textContent = time;
    (document.getElementById('summary-notes') as HTMLElement).textContent = notes || 'None';

    document.getElementById('step1')?.classList.add('hidden');
    document.getElementById('step2')?.classList.remove('hidden');

    // Update progress indicator
    const ind2 = document.getElementById('step2-indicator');
    const lbl2 = document.getElementById('step2-label');
    if (ind2) ind2.style.cssText = 'background: #0EA5E9; border-color: #0EA5E9; color: white;';
    if (lbl2) lbl2.style.color = '#0EA5E9';
  });

  // Back
  document.getElementById('back-btn')?.addEventListener('click', () => {
    document.getElementById('step2')?.classList.add('hidden');
    document.getElementById('step1')?.classList.remove('hidden');
  });

  // Confirm
  document.getElementById('confirm-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('confirm-btn') as HTMLButtonElement;
    const errorEl = document.getElementById('step2-error') as HTMLParagraphElement;

    btn.disabled = true;
    btn.textContent = 'Booking...';
    errorEl.classList.add('hidden');

    const { error } = await supabase.from('appointments').insert({
      patient_id: session!.user.id,
      treatment_type: formData.treatment_type,
      appointment_date: formData.appointment_date,
      appointment_time: formData.appointment_time,
      notes: formData.notes || null,
      status: 'pending',
    });

    if (error) {
      console.error('Supabase booking error:', error);
      errorEl.textContent = 'Booking failed. Please try again.';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Confirm Booking';
      return;
    }

    window.location.href = '/dashboard?booked=true';
  });
</script>
