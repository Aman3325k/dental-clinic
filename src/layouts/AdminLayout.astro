---
interface Props {
  title: string;
  activePage?: string;
}
const { title, activePage = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Admin — SmileCare</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/src/styles/global.css" />
</head>
<body style="background: #F8FAFC; margin: 0;">
  <div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside style="width: 240px; background: #0F172A; min-height: 100vh; position: fixed; left: 0; top: 0; display: flex; flex-direction: column;">
      <div style="padding: 1.5rem; border-bottom: 1px solid #1E293B;">
        <p style="font-size: 0.7rem; color: #64748B; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.25rem;">Admin Panel</p>
        <p style="font-family: 'DM Sans', sans-serif; font-weight: 800; color: white; font-size: 1.25rem;">SmileCare</p>
      </div>
      <nav style="flex: 1; padding: 1rem;">
        <a href="/admin" style={`display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 0.75rem; border-radius: 0.5rem; font-size: 0.875rem; text-decoration: none; margin-bottom: 0.25rem; transition: all 0.15s; ${activePage === 'dashboard' ? 'background: #6366F1; color: white;' : 'color: #94A3B8;'}`}>
          📋 Appointments
        </a>
        <a href="/admin/patients" style={`display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 0.75rem; border-radius: 0.5rem; font-size: 0.875rem; text-decoration: none; margin-bottom: 0.25rem; transition: all 0.15s; ${activePage === 'patients' ? 'background: #6366F1; color: white;' : 'color: #94A3B8;'}`}>
          👥 Patients
        </a>
        <a href="/admin/records" style={`display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 0.75rem; border-radius: 0.5rem; font-size: 0.875rem; text-decoration: none; margin-bottom: 0.25rem; transition: all 0.15s; ${activePage === 'records' ? 'background: #6366F1; color: white;' : 'color: #94A3B8;'}`}>
          📁 Records
        </a>
      </nav>
      <div style="padding: 1rem; border-top: 1px solid #1E293B;">
        <button id="admin-signout" style="color: #64748B; font-size: 0.875rem; background: none; border: none; cursor: pointer; padding: 0;">
          Sign out
        </button>
      </div>
    </aside>

    <!-- Main content -->
    <main style="margin-left: 240px; flex: 1; padding: 2rem;">
      <slot />
    </main>

  </div>

  <script>
    import { supabase } from '../lib/supabase';
    document.getElementById('admin-signout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/login';
    });
  </script>
</body>
</html>
